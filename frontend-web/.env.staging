# =============================================
# 校园易物 H5 端 · 测试环境配置
# =============================================

# 后端 API 基础路径
VITE_API_BASE=/api

# 后端真实地址(staging 联调服务器)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# 应用标题
VITE_APP_TITLE=校园易物 H5 (Staging)

# 管理后台地址
VITE_ADMIN_URL=http://localhost:5173/

# 文件上传大小上限(MB)
VITE_UPLOAD_MAX_SIZE_MB=10

# 全局请求超时(毫秒)
VITE_REQUEST_TIMEOUT=15000

# 是否启用 Mock 数据
VITE_USE_MOCK=false
