# =============================================
# 校园易物 H5 端 · 开发环境配置
# =============================================

# 后端 API 基础路径(由 Vite 代理转发,无需关心后端真实地址)
VITE_API_BASE=/api

# 后端真实地址(仅开发代理使用,生产环境不生效)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Dev Server 端口
VITE_APP_PORT=3000

# 应用标题
VITE_APP_TITLE=校园易物 H5

# 管理后台地址(用于"进入管理后台"跳转)
VITE_ADMIN_URL=http://localhost:5173/

# 文件上传大小上限(MB)
VITE_UPLOAD_MAX_SIZE_MB=10

# 全局请求超时(毫秒)
VITE_REQUEST_TIMEOUT=15000

# 是否启用 Mock 数据
VITE_USE_MOCK=false
