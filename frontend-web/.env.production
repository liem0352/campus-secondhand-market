# =============================================
# 校园易物 H5 端 · 生产环境配置
# =============================================

# 后端 API 基础路径(生产环境通过 Nginx/网关转发,可填绝对或相对)
VITE_API_BASE=/api

# 后端真实地址(仅开发代理使用,生产环境不生效)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# 应用标题
VITE_APP_TITLE=校园易物 H5

# 管理后台地址(用于"进入管理后台"跳转)
VITE_ADMIN_URL=https://admin.example.com/

# 文件上传大小上限(MB)
VITE_UPLOAD_MAX_SIZE_MB=20

# 全局请求超时(毫秒)
VITE_REQUEST_TIMEOUT=20000

# 是否启用 Mock 数据(生产环境强制 false)
VITE_USE_MOCK=false
