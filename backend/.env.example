# 复制为 .env 后按本机 MySQL 修改密码
DEBUG=True
SECRET_KEY=change-me-in-production

# ---------- MySQL（默认） ----------
DB_ENGINE=mysql
# 已安装 mysqlclient 时设为 false；否则 true 并用 PyMySQL
DB_USE_PYMYSQL=false
# 库名已从 family_finance 切换为 campus_market（校园二手交易）
DB_NAME=campus_market
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=3306

# ---------- 媒体文件（商品图 / 头像） ----------
# 上传文件落地目录（相对 BASE_DIR），前端通过 MEDIA_URL 拼接访问地址。
# 生产环境建议替换为对象存储（OSS/COS）并由 Nginx 反代。
MEDIA_ROOT=media
MEDIA_URL=/media/

# 若改用 SQLite：DB_ENGINE=sqlite

# 真机调试须让手机能访问电脑 IP；DEBUG=True 时 settings 默认 ALLOWED_HOSTS=*（无需写网段）
# 生产环境 DEBUG=False 时请写具体域名，例如：ALLOWED_HOSTS=127.0.0.1,localhost,192.168.20.40
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOW_ALL_ORIGINS=True

# LLM（可选）
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
