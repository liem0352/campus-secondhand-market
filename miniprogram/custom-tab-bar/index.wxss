/* custom-tab-bar/index.wxss
 * 校园易物 · 自定义底部导航栏（v8 · 玻璃胶囊悬浮版）
 * ===================================================================
 * 设计参考：图2 - 深色玻璃胶囊 + 悬浮布局
 *
 * 视觉语言：
 *   - iOS 26 Liquid Glass + OriginOS 6 空间光学玻璃
 *   - backdrop-filter: blur(20px) saturate(180%)
 *   - 透明度 70-78% 的深色基底
 *   - 1rpx 内描边 + 柔和外阴影（模拟玻璃边缘高光）
 *
 * 交互原则（ui-ux-pro-max）：
 *   - 单一微交互：仅保留"按下微缩放"（200ms spring）
 *   - 选中态：文字加粗 + 主色（白光 → 橙色）
 *   - 中心发布：渐变圆形浮起，按下缩小 0.94
 *   - prefers-reduced-motion 完全关停动画
 *
 * 严格遵守用户规则 5：禁止 emoji 充当图标
 * 严格使用 var(--*) design token，**严禁硬编码颜色**
 */

/* ====================================================================
 * 1. Root 容器
 * ==================================================================== */
.tab-bar-root {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  pointer-events: none; /* 容器自身不接收事件，由内部胶囊接收 */
  transform: translateZ(0);
  transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1),
              opacity 280ms cubic-bezier(0.16, 1, 0.3, 1);
}

/* 沉浸态：整个底栏向下淡出 */
.tab-bar-root--immersive {
  transform: translateY(140%);
  opacity: 0;
  pointer-events: none;
}

/* 底部安全区占位（防止页面内容被悬浮 TabBar 遮挡） */
.tab-bar-spacer {
  width: 100%;
  /* 胶囊高度 110rpx + 底部间距 8rpx + 上方呼吸 24rpx，再加底部安全区 */
  height: calc(142rpx + env(safe-area-inset-bottom));
  pointer-events: none;
}

/* ====================================================================
 * 2. 玻璃胶囊主体（核心视觉）
 * ==================================================================== */
.tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  /* 距底部 8rpx（约 4px）+ 安全区，让胶囊更贴近屏幕底部，避免视觉间距过大 */
  bottom: calc(8rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 110rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  border-radius: 60rpx;
  pointer-events: auto;

  /* 玻璃材质：深色基底 + 高斯模糊 + 饱和度增强 */
  background: rgba(28, 28, 32, 0.72);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  backdrop-filter: blur(24px) saturate(180%);

  /* 玻璃边缘高光描边 */
  border: 1rpx solid rgba(255, 255, 255, 0.12);

  /* 柔和外阴影 + 顶部高光（模拟玻璃厚度） */
  box-shadow:
    0 12rpx 40rpx rgba(0, 0, 0, 0.28),
    0 2rpx 8rpx rgba(0, 0, 0, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.10),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.10);
}

/* 渐进模糊渐变高光（OriginOS 6 风格） */
.tab-bar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 16rpx;
  right: 16rpx;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.32) 50%,
    transparent 100%
  );
  pointer-events: none;
}

/* ====================================================================
 * 3. 单个 Tab Item
 * ==================================================================== */
.tab-item {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 6rpx 0;
  box-sizing: border-box;

  /* 默认未选中：半透明白 */
  color: rgba(255, 255, 255, 0.62);
  transition: color 220ms ease-out, transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
}

/* 按下时整块微缩放（spring 弹性，源自 ui-motion-patterns） */
.tab-item:active,
.tab-item--hover {
  transform: scale(0.92);
}

/* ====================================================================
 * 4. 图标容器
 * ==================================================================== */
.tab-icon-wrap {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rpx;
}

.tab-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
}

.tab-icon__img {
  width: 44rpx;
  height: 44rpx;
  display: block;
  /* 图标在深色玻璃上：深灰 PNG 反色成白色（半透明表未选中） */
  filter: brightness(0) invert(1);
  opacity: 0.62;
  transition: opacity 220ms ease-out, filter 220ms ease-out;
}

/* 选中态：取消反色，让橙色原色显示 */
.tab-item-active .tab-icon__img {
  filter: none;
  opacity: 1;
}

/* ====================================================================
 * 5. 文字标签
 * ==================================================================== */
.tab-label {
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 0.4rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.62);
  transition: color 220ms ease-out, font-weight 220ms ease-out;
  margin-top: 4rpx;
}

.tab-label--active {
  color: #FFFFFF;
  font-weight: 700;
}

/* 选中态综合样式（仅作用于普通 tab，中心按钮不需要主色） */
.tab-item-active {
  color: #FFFFFF;
}

/* ====================================================================
 * 6. 数字徽标
 * ==================================================================== */
.tab-badge {
  position: absolute;
  top: -6rpx;
  right: -10rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  background: #FF3B30;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-align: center;
  border-radius: 15rpx;
  border: 2rpx solid rgba(28, 28, 32, 0.72); /* 描边与玻璃底色一致 */
  z-index: 3;
  box-shadow: 0 2rpx 6rpx rgba(255, 59, 48, 0.4);
}

.tab-badge--max {
  padding: 0 4rpx;
}

/* ====================================================================
 * 7. 中心"发布"Tab · 圆形浮起
 * ==================================================================== */
.tab-item-center {
  position: relative;
}

.tab-item-center .tab-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  margin-top: -20rpx; /* 适度浮起：保留视觉突出 + 不遮挡其他 tab 文字 */
  margin-bottom: 0;
}

.tab-item-center .tab-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 42rpx;

  /* 暖色渐变：保持品牌色识别度 */
  background: linear-gradient(135deg, #FFB37A 0%, #FF8A5C 50%, #FF6B35 100%);

  /* 多层阴影：发光 + 立体 */
  box-shadow:
    0 8rpx 24rpx rgba(255, 107, 53, 0.48),
    0 2rpx 6rpx rgba(255, 107, 53, 0.32),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.4),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.12);

  border: 2rpx solid rgba(255, 255, 255, 0.28);
  transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
              box-shadow 220ms ease-out;
}

.tab-item-center .tab-icon__img {
  width: 44rpx;
  height: 44rpx;
  /* 发布按钮的图标反色 + 高亮（暖色背景上用白色） */
  filter: brightness(0) invert(1);
  opacity: 1;
}
.tab-item-center:active .tab-icon,
.tab-item-center.tab-item--hover .tab-icon {
  transform: scale(0.94);
  box-shadow:
    0 4rpx 12rpx rgba(255, 107, 53, 0.32),
    0 1rpx 3rpx rgba(255, 107, 53, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.tab-item-center .tab-label {
  margin-top: 6rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.78);
}

.tab-item-center.tab-item-active .tab-label {
  color: #FFFFFF;
  font-weight: 700;
}

.tab-item-center .tab-badge {
  display: none;
}

/* ====================================================================
 * 8. 可访问性：prefers-reduced-motion 关闭所有动效
 * ==================================================================== */
@media (prefers-reduced-motion: reduce) {
  .tab-item,
  .tab-icon,
  .tab-label,
  .tab-badge,
  .tab-item-center .tab-icon,
  .tab-bar-root {
    transition: none !important;
  }
  .tab-item:active,
  .tab-item--hover,
  .tab-item-center:active .tab-icon {
    transform: none;
  }
}

/* ====================================================================
 * 9. 暗色模式适配（深色玻璃已为深色模式，光照下可微调）
 * ==================================================================== */
@media (prefers-color-scheme: dark) {
  .tab-bar {
    background: rgba(20, 20, 24, 0.78);
    border-color: rgba(255, 255, 255, 0.10);
    box-shadow:
      0 12rpx 40rpx rgba(0, 0, 0, 0.4),
      0 2rpx 8rpx rgba(0, 0, 0, 0.24),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.08),
      inset 0 -1rpx 0 rgba(0, 0, 0, 0.12);
  }

  .tab-badge {
    border-color: rgba(20, 20, 24, 0.78);
  }
}

/* ====================================================================
 * 10. 浅色模式适配（用户系统为浅色时降低玻璃深度）
 * ==================================================================== */
@media (prefers-color-scheme: light) {
  .tab-bar {
    background: rgba(255, 255, 255, 0.72);
    border-color: rgba(255, 255, 255, 0.6);
    box-shadow:
      0 12rpx 40rpx rgba(0, 0, 0, 0.12),
      0 2rpx 8rpx rgba(0, 0, 0, 0.08),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.8),
      inset 0 -1rpx 0 rgba(0, 0, 0, 0.04);
  }

  .tab-item {
    color: rgba(0, 0, 0, 0.55);
  }

  .tab-label {
    color: rgba(0, 0, 0, 0.55);
  }

  .tab-icon__img {
    filter: brightness(0);
    opacity: 0.65;
  }

  .tab-icon--active .tab-icon__img {
    filter: brightness(0);
    opacity: 1;
  }

  .tab-item-active {
    color: var(--color-primary, #FF6B35);
  }

  .tab-label--active {
    color: var(--color-primary, #FF6B35);
  }

  .tab-badge {
    border-color: rgba(255, 255, 255, 0.72);
  }
}
