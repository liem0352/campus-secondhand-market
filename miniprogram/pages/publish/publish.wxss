/* pages/publish/publish.wxss
   发布页样式 v3 —— 校园易物（融合设计系统重构版）
   --------------------------------------------------------------------
   设计语言：Apple Liquid Glass + MD3 Expressive + OriginOS 6 空间光学
   关键 token：颜色 / 字号 / 间距 / 圆角 / 阴影 / 动效 全部来自 app.wxss
   实现要点：
     1) 液态玻璃（半透 + 顶部高光 + 多层阴影 + 边缘内发光）
     2) Spring 弹性动效（cubic-bezier(0.34, 1.56, 0.64, 1)）
     3) 光感设计（光圈 / 渐变光带 / 环境光）
     4) 严格使用 var(--*) token，**严禁硬编码颜色**
     5) 触达目标 ≥ 88rpx；支持 prefers-reduced-motion
     6) 校验错误抖动（horizontal-shake） + 边框变红 */

/* =====================================================================
 * 0. 页面基线
 * ===================================================================== */
.publish-page {
  padding: 0 var(--space-3) 0;
  background: var(--gradient-page);
  min-height: 100vh;
}

/* =====================================================================
 * 0.5 自定义顶栏（透明 + AI 胶囊放左侧）
 * ===================================================================== */
.publish-safe-top {
  width: 100%;
}

.publish-navbar {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) 0 var(--space-3);
  min-height: 88rpx;
}

.publish-navbar__spacer {
  flex: 1;
}

/* AI 一键发布胶囊（液态玻璃 + 主色渐变） */
.publish-navbar__ai {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  height: 64rpx;
  padding: 0 var(--space-3);
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, #ff9568 0%, #ff7a45 50%, #ff6b35 100%);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.45);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.25),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.08),
    0 6rpx 14rpx rgba(255, 107, 53, 0.32),
    0 2rpx 6rpx rgba(255, 107, 53, 0.14);
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
  overflow: hidden;
  isolation: isolate;
}

.publish-navbar__ai--pressed {
  transform: scale(0.96);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5),
    0 2rpx 6rpx rgba(255, 107, 53, 0.24);
}

.publish-navbar__ai::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.6) 50%, transparent 100%);
  pointer-events: none;
}

.publish-navbar__ai-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  filter: invert(1) brightness(1.4);
}

.publish-navbar__ai-text {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  letter-spacing: 0.5rpx;
  line-height: 1;
  white-space: nowrap;
}

.publish-navbar__ai-badge {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  height: 24rpx;
  padding: 0 8rpx;
  border-radius: var(--radius-pill);
  font-size: 10rpx;
  font-weight: var(--font-weight-semibold);
  line-height: 1;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  white-space: nowrap;
}

.publish-navbar__ai-badge--loading {
  background: rgba(0, 0, 0, 0.22);
}

.publish-navbar__ai-badge--done {
  background: rgba(7, 193, 96, 0.9);
  border-color: rgba(255, 255, 255, 0.5);
}

.publish-navbar__ai-badge--fallback {
  background: rgba(255, 255, 255, 0.28);
}

.publish-navbar__ai-dot {
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  border-radius: var(--radius-circle);
  background: #fff;
  box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.6);
  animation: pulse-dot-nav 1.2s ease-in-out infinite;
}

@keyframes pulse-dot-nav {
  0%   { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7); }
  70%  { box-shadow: 0 0 0 8rpx rgba(255, 255, 255, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
}

.publish-navbar__ai-check {
  display: inline-block;
  width: 12rpx;
  height: 6rpx;
  border-left: 2rpx solid #fff;
  border-bottom: 2rpx solid #fff;
  transform: rotate(-45deg) translateY(-1rpx);
}

/* =====================================================================
 * 0.5 液态玻璃公共类（页面内复用，app.wxss 已有同款工具类）
 *     - glass-card：标准液态玻璃卡片
 *     - glass-section-header：带 section 编号的标题头
 * ===================================================================== */
.glass-card {
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  /* 顶部白色高光（玻璃折光） */
  position: relative;
  overflow: hidden;
}

.glass-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.8) 50%, transparent 100%);
  pointer-events: none;
}

.glass-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-1);
  margin-bottom: var(--space-2);
}

.glass-section-header .section-header__left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.glass-section-header .section-header__num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 48rpx;
  height: 32rpx;
  padding: 0 var(--space-2);
  border-radius: var(--radius-pill);
  background: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: 0.5rpx;
  line-height: 1;
}

/* =====================================================================
 * 1. AI 一键发布胶囊（已上移至自定义顶栏，见 0.5 节）
 * ===================================================================== */

/* =====================================================================
 * 2. AI 草稿文字（液态玻璃 input + 字符计数）
 * ===================================================================== */
.ai-draft-row {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  height: 72rpx;
  padding: 0 var(--space-3);
  border-radius: var(--radius-base);
  background: var(--glass-bg-light-3);
  border: 2rpx solid var(--glass-border-light);
  box-shadow: var(--shadow-glass-sm);
  margin-bottom: var(--space-3);
  transition: border-color var(--duration-fast) var(--ease-out),
              background var(--duration-fast) var(--ease-out),
              box-shadow var(--duration-fast) var(--ease-out);
}

.ai-draft-row:focus-within {
  border-color: var(--color-primary);
  background: #fff;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5),
    0 0 0 4rpx rgba(255, 107, 53, 0.12),
    0 4rpx 12rpx rgba(255, 107, 53, 0.1);
}

.ai-draft-row__icon {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: var(--radius-sm);
  background: var(--color-primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-draft-row__icon-img {
  width: 22rpx;
  height: 22rpx;
  opacity: 0.85;
}

.ai-draft-input {
  flex: 1;
  height: 100%;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: transparent;
  border: none;
  min-width: 0;
}

.ai-draft-input:focus {
  outline: none;
}

.ai-draft-row__count {
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.5rpx;
}

.ai-draft-row__count--warn {
  color: var(--color-warning);
  font-weight: var(--font-weight-semibold);
}

/* =====================================================================
 * 3. 商品图片（9 宫格 + 玻璃感添加按钮）
 * ===================================================================== */
.image-section {
  margin-bottom: var(--space-3);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-1);
  margin-bottom: var(--space-2);
}

.section-header__left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.section-header__num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 44rpx;
  height: 28rpx;
  padding: 0 var(--space-2);
  border-radius: var(--radius-pill);
  background: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: 0.5rpx;
  line-height: 1;
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.section-meta {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.image-item,
.image-add {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-base);
  overflow: hidden;
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}

.image-item {
  border: 2rpx solid var(--color-bg-divider);
  box-shadow: var(--shadow-glass-sm);
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
}

.image-thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--glass-bg-dark-2);
  border-radius: var(--radius-pill);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.18);
  transition: transform var(--duration-fast) var(--ease-spring),
              background var(--duration-fast) var(--ease-out);
}

.image-remove--active {
  transform: scale(0.88);
  background: var(--color-error);
  border-color: rgba(255, 255, 255, 0.5);
}

.remove-icon {
  width: 24rpx;
  height: 24rpx;
  color: var(--color-text-inverse);
}

/* 添加图片按钮：液态玻璃风格 */
.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx dashed rgba(255, 107, 53, 0.45);
  color: var(--color-primary);
  background: var(--color-primary-softer);
  transition: border-color var(--duration-base) var(--ease-out),
              color var(--duration-base) var(--ease-out),
              transform var(--duration-base) var(--ease-spring),
              background var(--duration-base) var(--ease-out);
}

.image-add--active {
  border-color: var(--color-primary);
  border-style: solid;
  background: var(--color-primary-soft);
  transform: scale(0.97);
}

.image-add__plus {
  width: 52rpx;
  height: 52rpx;
  border-radius: var(--radius-circle);
  background: var(--gradient-warm);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.4),
              inset 0 2rpx 0 rgba(255, 255, 255, 0.5);
  margin-bottom: 2rpx;
}

.add-icon {
  width: 30rpx;
  height: 30rpx;
  color: #fff;
  filter: invert(1) brightness(2);
}

.add-text {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.add-hint {
  font-size: 10rpx;
  color: var(--color-text-tertiary);
}

/* 上传中提示 */
.upload-hint {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-3);
  padding: var(--space-2) var(--space-3);
  background: var(--color-primary-softer);
  border-radius: var(--radius-base);
  color: var(--color-primary);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
}

.upload-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid rgba(255, 107, 53, 0.2);
  border-top-color: var(--color-primary);
  border-radius: var(--radius-circle);
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* =====================================================================
 * 4. 表单卡片（液态玻璃 + label + focus 液态效果 + 错误态抖动）
 * ===================================================================== */
.form-card {
  border-radius: var(--radius-base);
  padding: var(--space-1) 0;
  margin-bottom: var(--space-3);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
}

.form-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  min-height: 88rpx;
  padding: var(--space-1) var(--space-4);
  border-bottom: 2rpx solid var(--color-bg-divider);
  transition: background var(--duration-fast) var(--ease-out);
}

.form-row:last-child,
.form-row--last {
  border-bottom: none;
}

.form-row--column {
  flex-direction: column;
  align-items: stretch;
  padding: var(--space-2) var(--space-4);
  gap: var(--space-2);
}

.form-label-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.form-label-wrap--between {
  justify-content: space-between;
  width: 100%;
}

.form-label {
  display: inline-flex;
  align-items: center;
  height: 32rpx;
  padding: 0 var(--space-2);
  border-radius: var(--radius-sm);
  background: var(--color-bg-page);
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-semibold);
  letter-spacing: 0.5rpx;
  line-height: 1;
}

.form-row--column .form-label {
  background: transparent;
  padding: 0;
  height: auto;
}

.form-label.required::before {
  content: '*';
  color: var(--color-error);
  margin-right: 4rpx;
  font-size: var(--font-size-base);
  line-height: 1;
}

.form-row__count {
  font-variant-numeric: tabular-nums;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 48rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: transparent;
  border: none;
  text-align: right;
  transition: color var(--duration-fast) var(--ease-out);
  border-radius: var(--radius-sm);
  padding: 0 4rpx;
}

.form-input--price {
  text-align: center;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  font-variant-numeric: tabular-nums;
  color: var(--color-primary);
  letter-spacing: 0.5rpx;
}

.form-input:focus {
  outline: none;
}

/* 错误态：边框变红 + 抖动 */
.form-input--error {
  color: var(--color-error);
  background: var(--color-error-soft);
  animation: horizontal-shake 0.4s var(--ease-spring) both;
}

.form-textarea--error,
.form-picker__inner--error {
  border-color: var(--color-error) !important;
  background: var(--color-error-soft) !important;
  animation: horizontal-shake 0.4s var(--ease-spring) both;
}

.condition-chip--error {
  animation: horizontal-shake 0.4s var(--ease-spring) both;
}

@keyframes horizontal-shake {
  0%, 100% { transform: translateX(0); }
  20%      { transform: translateX(-8rpx); }
  40%      { transform: translateX(8rpx); }
  60%      { transform: translateX(-6rpx); }
  80%      { transform: translateX(6rpx); }
}

.placeholder-muted {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-base);
}

.form-price-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-2);
  justify-content: flex-end;
}

.form-price-prefix {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 var(--space-1);
  border-radius: var(--radius-sm);
  background: var(--color-primary-soft);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  line-height: 1;
  font-variant-numeric: tabular-nums;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
}

.form-price-suffix {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.form-picker {
  flex: 1;
}

.form-picker__inner {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-2);
  min-height: 48rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid transparent;
  background: transparent;
  transition: background var(--duration-fast) var(--ease-out),
              border-color var(--duration-fast) var(--ease-out);
}

.form-picker__text {
  font-weight: var(--font-weight-semibold);
}

.form-picker__arrow {
  width: 32rpx;
  height: 32rpx;
  border-radius: var(--radius-circle);
  background: var(--glass-bg-light-3);
  border: 2rpx solid var(--glass-border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-glass-sm);
}

.picker-arrow {
  width: 20rpx;
  height: 20rpx;
  color: var(--color-text-tertiary);
}

/* 成色 4 宫格：等级色 + 选中态玻璃感 */
.condition-options {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--space-2);
}

.condition-chip {
  position: relative;
  flex: 1 1 0;
  min-width: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 60rpx;
  padding: 0 var(--space-2);
  border-radius: var(--radius-pill);
  background: var(--glass-bg-light-3);
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-bg-divider);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  transition: transform var(--duration-fast) var(--ease-spring),
              background var(--duration-fast) var(--ease-out),
              color var(--duration-fast) var(--ease-out),
              border-color var(--duration-fast) var(--ease-out),
              box-shadow var(--duration-fast) var(--ease-out);
}

.condition-chip__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-circle);
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.8);
  flex-shrink: 0;
}

.condition-chip--active,
.condition-chip:active {
  background: var(--gradient-warm);
  color: #fff;
  border-color: rgba(255, 255, 255, 0.4);
  font-weight: var(--font-weight-semibold);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.08),
    0 4rpx 12rpx rgba(255, 107, 53, 0.35),
    0 2rpx 4rpx rgba(255, 107, 53, 0.2);
  transform: translateY(-2rpx) scale(1.02);
}

.condition-chip--active .condition-chip__dot {
  background: #fff !important;
  box-shadow: 0 0 0 2rpx rgba(255, 107, 53, 0.4);
}

/* 描述 textarea */
.form-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: var(--space-2) var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: var(--line-height-base);
  background: var(--color-bg-page);
  border-radius: var(--radius-base);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color var(--duration-fast) var(--ease-out),
              background var(--duration-fast) var(--ease-out),
              box-shadow var(--duration-fast) var(--ease-out);
}

.form-textarea:focus {
  border-color: var(--color-primary);
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.1);
}

/* =====================================================================
 * 5. 草稿状态条 + 立即发布
 * ===================================================================== */
.bottom-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-top: var(--space-3);
  margin-bottom: var(--space-3);
}

.draft-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx;
  min-height: 32rpx;
}

.draft-row__left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-2);
  min-width: 0;
}

.draft-row__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-circle);
  background: var(--color-success);
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.18);
  flex-shrink: 0;
  animation: anim-pulse 1.6s var(--ease-in-out) infinite;
}

.draft-clear {
  padding: var(--space-1) var(--space-2);
  cursor: pointer;
  flex-shrink: 0;
  border-radius: var(--radius-pill);
  transition: background var(--duration-fast) var(--ease-out);
}

.draft-clear:active {
  background: var(--color-bg-hover);
}

.draft-hint {
  flex: 1;
  line-height: 1.4;
  min-width: 0;
  overflow: hidden;
}

.submit-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  background: var(--gradient-warm) !important;
  color: #fff !important;
  font-size: var(--font-size-base) !important;
  font-weight: var(--font-weight-semibold) !important;
  letter-spacing: 1rpx !important;
  height: 80rpx !important;
  line-height: 1 !important;
  border-radius: var(--radius-base) !important;
  border: none !important;
  box-shadow:
    var(--shadow-orange-inset),
    var(--shadow-primary-md) !important;
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out),
              opacity var(--duration-fast) var(--ease-out) !important;
}

.submit-btn.btn-active,
.submit-btn:active {
  transform: scale(0.98) translateY(1rpx);
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 53, 0.2) !important;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.submit-btn__text {
  display: inline-block;
  line-height: 1;
  text-align: center;
}

/* =====================================================================
 * 6. 动画扩展（stagger 渐入 + 错误抖动）
 * ===================================================================== */
.anim-fade-up {
  animation: fade-in-up var(--duration-base) var(--ease-spring) both;
  animation-delay: var(--anim-delay, 0ms);
}

.anim-scale-in {
  animation: scale-in var(--duration-base) var(--ease-spring) both;
  animation-delay: var(--anim-delay, 0ms);
}

@keyframes fade-in-up {
  0%   { transform: translateY(20rpx); opacity: 0; }
  100% { transform: translateY(0);     opacity: 1; }
}

@keyframes scale-in {
  0%   { transform: scale(0.9); opacity: 0; }
  100% { transform: scale(1);   opacity: 1; }
}

/* =====================================================================
 * 7. 可访问性：尊重 prefers-reduced-motion
 * ===================================================================== */
@media (prefers-reduced-motion: reduce) {
  .anim-fade-up,
  .anim-scale-in,
  .ai-banner__dot,
  .draft-row__dot {
    animation: none !important;
    transition: none !important;
  }
  .form-input--error,
  .form-textarea--error,
  .form-picker__inner--error,
  .condition-chip--error {
    animation: none !important;
  }
}
