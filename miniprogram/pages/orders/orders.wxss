/* pages/orders/orders.wxss
 * ================================================================
 * 订单页样式 · 校园易物（Phase 4.0 · fusion-ui-design v2）
 * ================================================================
 * 融合设计语言：
 *   - Part 22.10 ColorOS 16 充电岛：进行中订单能量波进度胶囊
 *   - Part 22.9  OriginOS 6  空间玻璃：弹性入场 + 错落列表
 *   - Part 22.2  iOS 26 Liquid Glass：折射层 + 顶/底高光带
 *
 * 涉及 token：
 *   --color-* / --font-* / --space-* / --radius-* / --shadow-*
 *   --ease-coloros-quick / --ease-m3-spatial-default
 *   --ease-magicos-capsule / --ease-oneui-smooth
 *   --liquid-refract-prism / --charge-pulse-start/end
 *
 * 设计原则：
 *   1) 所有颜色/字号/动效必须使用 var(--*) token（用户规则 5）
 *   2) 每个新动效/类在注释中标注【来源】
 *   3) 通过 prefers-reduced-motion 减弱动效（用户偏好）
 * ================================================================ */

/* =====================================================================
 * 0. 减弱动效偏好（prefers-reduced-motion）· 兜底
 *   - 来源：通用可访问性规范 + Apple/Material 减弱动效建议
 *   - 当用户在系统层开启"减弱动效"时，把所有动画压缩到 0.01ms，
 *     让页面直接呈现终态，不播放 spring / shimmer / wave
 * ===================================================================== */
@media (prefers-reduced-motion: reduce) {
  .order-card,
  .tab-item__bar,
  .charge-capsule__wave,
  .charge-capsule__fill {
    animation: none !important;
    transition: none !important;
  }
  .anim-stagger-in,
  .anim-m3-spatial-in,
  .anim-charge-wave,
  .anim-progress-fill {
    animation: none !important;
  }
}

/* =====================================================================
 * 1. 页面根容器
 * ===================================================================== */
.orders-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* =====================================================================
 * 2. 顶部 Tab 横向滚动条
 *   - 按下动效【来源：ColorOS 16 干脆利落 spring-coloros】
 *     在 WXML 中为 scroll-view 加上 .spring-coloros 工具类
 *   - 标签切换文字 spring-oneui【来源：One UI 9 流畅轻快】
 *   - 下方滑块用 anim-m3-spatial-in 弹性出现
 * ===================================================================== */
.tab-bar {
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
  display: flex;
  flex-direction: row;
  align-items: center;
  white-space: nowrap;
  height: 88rpx;
  background: var(--color-bg-card);
  border-bottom: var(--border-width) solid var(--color-bg-divider);
  padding: 0 var(--space-2);
  box-shadow: var(--shadow-sm);
}

.tab-item {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 var(--space-3);
  flex-shrink: 0;
  min-width: 96rpx;
  /* 44pt 触控热区 */
}

.tab-item__label {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
  line-height: 1;
  /* spring-oneui：One UI 9 流畅轻快（damping=0.7, stiffness=500） */
  transition: color var(--duration-spring-default) var(--ease-oneui-smooth),
              font-weight var(--duration-spring-default) var(--ease-oneui-smooth);
}

.tab-item--active .tab-item__label {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  font-size: var(--font-size-md);
}

.tab-item__bar {
  position: absolute;
  left: 50%;
  bottom: 12rpx;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary);
  /* anim-m3-spatial-in：MD3 Expressive 弹性入场 */
  box-shadow: var(--light-diffuse);
}

/* 旧 keyframe 保留兼容（沿用 anim-m3-spatial-in 替代） */
@keyframes tab-bar-grow {
  0%   { width: 0; opacity: 0; }
  100% { width: 48rpx; opacity: 1; }
}

.tab-item--hover {
  background: var(--color-bg-hover);
}

/* =====================================================================
 * 3. 订单列表容器
 * ===================================================================== */
.order-list {
  padding: var(--space-3) var(--space-4) 160rpx;
}

/* =====================================================================
 * 4. 订单卡片
 *   - 外观【来源：iOS 26 Liquid Glass 液态玻璃 + OriginOS 6 空间玻璃】
 *     使用 .glass-light-soft 工具类，提供：
 *       · 半透白色 + 顶部 inset 高光
 *       · 多层柔和外阴影（环境光 + 关键光）
 *       · 折射层（iOS 26 标志性光学折射，--liquid-refract-prism）
 *   - 入场【来源：MD3 Expressive 弹性入场 anim-m3-spatial-in】
 *   - 错落【来源：OriginOS 6 弹性 bounce-in 错落 anim-stagger-in】
 *   - 减少循环：卡片入场只播一次，使用 forwards
 * ===================================================================== */
.order-card {
  position: relative;
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-3);
  border-radius: var(--radius-md);
  /* iOS 26 Liquid Glass 折射层（顶/底高光带 + 边缘微光） */
  box-shadow: var(--liquid-refract-prism),
              var(--shadow-glass-md);
  /* 玻璃卡按下时轻微下沉 + 增强环境光【来源：OriginOS 6 增强光】 */
  transition: transform var(--duration-spring-default) var(--ease-ios-spring),
              box-shadow var(--duration-spring-base) var(--ease-out);
  overflow: hidden;
}

.order-card:active {
  transform: scale(0.985);
  box-shadow: var(--liquid-refract-prism),
              var(--light-enhanced),
              var(--shadow-glass-sm);
}

/* 卡片顶部高光带（iOS 26 Liquid Glass 折光 · 增强立体感） */
.order-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.7) 50%,
    transparent 100%);
  pointer-events: none;
}

/* 卡片底部微光（OriginOS 6 边缘光 · bottom 顶部聚焦） */
.order-card::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 107, 53, 0.12) 50%,
    transparent 100%);
  pointer-events: none;
}

/* 状态修饰：进行中（待发货/待收货）增加左侧能量条颜色 */
.order-card--progress {
  border-left: 4rpx solid var(--color-primary);
}

/* =====================================================================
 * 5. 卡片头
 * ===================================================================== */
.order-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

.order-card__no {
  font-family: var(--font-family-mono);
  letter-spacing: 1rpx;
}

.order-card__status {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  /* 状态色切换走 spring-oneui（One UI 9 流畅轻快） */
  transition: color var(--duration-spring-default) var(--ease-oneui-smooth);
}

.order-card__role {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-regular);
}

/* =====================================================================
 * 6. ColorOS 16 充电岛能量波进度胶囊【来源：Part 22.10 ColorOS 16.1】
 *   - 充电岛：胶囊状进度条 + 能量波动画
 *   - 进度条填充 anim-progress-fill
 *   - 能量波 anim-charge-wave（ease-magicos-capsule 灵动胶囊曲线）
 *   - 颜色使用 --charge-pulse-start/end token
 * ===================================================================== */
.charge-capsule {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
  padding: var(--space-2) var(--space-3);
  background: var(--color-primary-softer);
  border-radius: var(--radius-pill);
  border: var(--border-width) solid var(--color-primary-soft);
}

.charge-capsule__bar {
  position: relative;
  flex: 1;
  height: 14rpx;
  border-radius: var(--radius-pill);
  background: var(--color-bg-page);
  overflow: hidden;
}

.charge-capsule__fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: var(--p, 0%);
  background: var(--charge-bar-fill);
  border-radius: var(--radius-pill);
  transform-origin: left center;
  /* anim-progress-fill：进度条弹簧式增长 */
  box-shadow: 0 0 8rpx rgba(76, 175, 80, 0.5);
}

/* 能量波层：覆盖在填充层上，循环呼吸，模拟 ColorOS 16 充电岛脉冲 */
.charge-capsule__wave {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.6) 50%,
    transparent 100%);
  background-size: 50% 100%;
  background-repeat: no-repeat;
  transform-origin: center;
  pointer-events: none;
  /* anim-charge-wave：充电岛能量波扩散（ease-magicos-capsule） */
}

.charge-capsule__text {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-success);
  flex-shrink: 0;
  white-space: nowrap;
}

/* =====================================================================
 * 7. 商品行（图 + 标题 + 价格 + 对方头像）
 * ===================================================================== */
.order-card__body {
  display: flex;
  gap: var(--space-3);
  align-items: stretch;
  margin-bottom: var(--space-3);
}

.order-card__cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-base);
  background: var(--color-bg-page);
  flex-shrink: 0;
  object-fit: cover;
  border: var(--border-width) solid var(--color-bg-divider);
}

.order-card__meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.order-card__title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-card__price {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  font-family: var(--font-family-mono);
  line-height: 1.2;
  margin-top: var(--space-1);
}

.order-card__counter {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  margin-top: var(--space-1);
}

.order-card__avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-pill);
  background: var(--color-bg-page);
  flex-shrink: 0;
  border: var(--border-width) solid var(--color-bg-divider);
}

.order-card__counter-name {
  line-height: 1;
}

/* =====================================================================
 * 8. 步骤条（保留原逻辑，新增 MD3 Expressive 切换反馈）
 *   - 步骤点切换【来源：MD3 Expressive spring-m3-fast】
 *   - 步骤点激活时增加 OriginOS 6 增强光
 * ===================================================================== */
.stepper {
  display: flex;
  align-items: flex-start;
  padding: var(--space-3) 0;
  border-top: var(--border-width) solid var(--color-bg-divider);
  border-bottom: var(--border-width) solid var(--color-bg-divider);
  margin-bottom: var(--space-3);
}

.stepper__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  gap: var(--space-1);
  width: 120rpx;
}

.stepper__dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: var(--radius-pill);
  background: var(--color-bg-page);
  color: var(--color-text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  border: var(--border-width) solid var(--color-bg-divider);
  /* spring-m3-fast：MD3 Expressive fast spatial 切换（约 350ms） */
  transition: all var(--duration-spring-default) var(--ease-m3-spatial-fast);
}

.stepper__num {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  line-height: 1;
}

.stepper__icon {
  width: 24rpx;
  height: 24rpx;
  color: var(--color-text-inverse);
}

.stepper__label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  text-align: center;
  line-height: 1.2;
  white-space: nowrap;
  transition: color var(--duration-spring-default) var(--ease-m3-spatial-fast);
}

.stepper__line {
  flex: 1;
  height: 4rpx;
  background: var(--color-bg-divider);
  margin-top: 16rpx;
  min-width: 24rpx;
  transition: background var(--duration-spring-base) var(--ease-m3-spatial-fast);
}

.stepper__line--done {
  background: var(--color-primary);
}

.stepper__item--done .stepper__dot {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-color: var(--color-primary);
}

.stepper__item--done .stepper__label {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

/* 当前激活：OriginOS 6 增强光（中心点高光） */
.stepper__item--active .stepper__dot {
  box-shadow: var(--light-enhanced-center);
  transform: scale(1.08);
}

.stepper__item--active .stepper__label {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* =====================================================================
 * 9. 备注
 * ===================================================================== */
.order-card__remark {
  padding: var(--space-2);
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-3);
  line-height: 1.5;
}

/* =====================================================================
 * 10. 操作栏
 *   - 按钮基类 spring-magicos【来源：MagicOS 10 灵动胶囊】
 *     （damping=0.65, stiffness=450，约 350ms）
 *   - 按下时使用 ColorOS 16 弥散光反馈
 * ===================================================================== */
.order-card__actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
  flex-wrap: wrap;
}

.order-card__btn {
  min-width: 144rpx;
  height: 64rpx;
  font-size: var(--font-size-sm);
  padding: 0 var(--space-3);
  border-radius: var(--radius-pill);
  /* spring-magicos：灵动胶囊曲线（damping=0.65, stiffness=450） */
}

/* =====================================================================
 * 11. 时间
 * ===================================================================== */
.order-card__time {
  text-align: right;
  font-family: var(--font-family-mono);
}

/* =====================================================================
 * 12. 列表底部
 * ===================================================================== */
.list-footer {
  padding: var(--space-4) 0;
  text-align: center;
}

/* =====================================================================
 * 13. 空状态
 * ===================================================================== */
.empty-state-wrap {
  min-height: 60vh;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx var(--space-4);
  gap: var(--space-2);
}

.empty-state__icon {
  width: 240rpx;
  height: 240rpx;
  opacity: 0.7;
}

.empty-state__title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-top: var(--space-3);
}

.empty-state__sub {
  line-height: 1.4;
}
