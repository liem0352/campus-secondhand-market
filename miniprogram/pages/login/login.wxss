/* pages/login/login.wxss
 * 校园易物 · 登录页样式 v3（融合设计系统重构）
 * ===================================================================
 * 视觉关键词：液态玻璃 + Spring 弹性 + 光感设计 + 暖橙主色
 * 严格使用 var(--*) design token，**严禁硬编码颜色**（除阴影/光感场景）
 *
 * 主要贡献：
 *   - 顶部品牌区：渐变 + 双层光晕（4s 呼吸循环）
 *   - 玻璃登录卡：半透白 + 顶部高光 + 多层阴影
 *   - Tab 胶囊指示器：Spring 弹性滑动
 *   - 输入框：focus 时底部光带从中心展开
 *   - 协议 checkbox：玻璃感 + 勾选动画
 *   - 主按钮：主色渐变 + 玻璃高光 + Spring 按下
 *   - 第三方登录：纯 SVG 图标 + 玻璃按钮
 *   - 入场动画：卡片从下方淡入 + 缩放
 *   - 支持 prefers-reduced-motion（关闭动效）
 */

/* ====================================================================
 * 1. 页面容器
 * ==================================================================== */
.login-page {
  position: relative;
  min-height: 100vh;
  background: var(--color-bg-page);
  /* 暖白渐变：与全局 --gradient-page 同步 */
  background-image: var(--gradient-page);
  /* 底部预留：iPhone X+ 的 home indicator（env 安全区），非 iOS 上约 0 */
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-x: hidden;
  overflow-y: auto;
}

.safe-area-bottom-spacer {
  height: env(safe-area-inset-bottom);
}

/* ====================================================================
 * 2. 品牌区：Logo + 品牌名 + 光感光晕呼吸
 * ==================================================================== */
.brand {
  position: relative;
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 0 var(--space-6);
  color: var(--color-text-inverse);
  isolation: isolate;
}

/* 光感光晕：双层 ambient 环境光，4s 呼吸循环 */
.brand__halo {
  position: absolute;
  top: 60rpx;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 480rpx;
  height: 480rpx;
  border-radius: var(--radius-circle);
  background: radial-gradient(
    circle at 50% 50%,
    rgba(255, 138, 92, 0.28) 0%,
    rgba(255, 107, 53, 0.18) 35%,
    transparent 70%
  );
  filter: blur(20rpx);
  pointer-events: none;
  z-index: -1;
  animation: haloBreathe 4s var(--ease-in-out) infinite;
}
.brand__halo--2 {
  width: 320rpx;
  height: 320rpx;
  top: 80rpx;
  background: radial-gradient(
    circle at 50% 50%,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 255, 255, 0.18) 40%,
    transparent 70%
  );
  animation-delay: -2s;
}
@keyframes haloBreathe {
  0%, 100% { transform: translate(-50%, -50%) scale(1);   opacity: 0.7; }
  50%      { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
}

.brand__logo-wrap {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-xl);
  background: var(--gradient-glass);
  border: var(--glass-border-strong);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.8),
    0 12rpx 32rpx rgba(229, 90, 43, 0.28),
    0 4rpx 12rpx rgba(229, 90, 43, 0.16);
  margin-bottom: var(--space-3);
  overflow: hidden;
  animation: logoFloat 6s var(--ease-in-out) infinite;
}
@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-4rpx); }
}

.brand__logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  filter: drop-shadow(0 4rpx 12rpx rgba(229, 90, 43, 0.35));
}

.brand__name {
  font-size: var(--font-size-4xl);
  font-weight: var(--font-weight-extrabold);
  letter-spacing: 6rpx;
  line-height: var(--line-height-tight);
  text-shadow: 0 4rpx 12rpx rgba(204, 77, 34, 0.25);
  color: var(--color-text-primary);
}

.brand__slogan {
  margin-top: var(--space-2);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  letter-spacing: 4rpx;
  color: var(--color-text-secondary);
}

.brand__tagline {
  margin-top: var(--space-1);
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  letter-spacing: 2rpx;
}

/* ====================================================================
 * 3. 后端警告（液态玻璃橘色高亮）
 * ==================================================================== */
.backend-warn {
  position: relative;
  z-index: 10;
  margin: 0 var(--space-4) var(--space-3);
  padding: var(--space-3) var(--space-4);
  background: linear-gradient(135deg, var(--cream-50) 0%, var(--orange-50) 100%);
  border: var(--border-width) solid var(--orange-200);
  border-radius: var(--radius-md);
  display: flex;
  gap: var(--space-3);
  box-shadow: var(--shadow-primary-sm);
}
.warn-badge {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-circle);
  background: var(--gradient-warm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-primary-sm);
  border: var(--glass-border-strong);
}
.warn-badge__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-circle);
  background: var(--color-text-inverse);
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.4);
}
.warn-text { flex: 1; min-width: 0; }
.warn-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary-pressed);
  margin-bottom: var(--space-1);
}
.warn-hint {
  font-size: var(--font-size-sm);
  color: var(--warm-600);
  line-height: var(--line-height-base);
  word-break: break-all;
  opacity: 0.9;
}
.warn-actions {
  display: flex;
  gap: var(--space-2);
  margin-top: var(--space-2);
}
.warn-btn {
  padding: 8rpx var(--space-3);
  font-size: var(--font-size-sm);
  border: var(--border-width) solid var(--color-primary);
  color: var(--color-primary);
  border-radius: var(--radius-pill);
  background: var(--color-bg-card);
  text-align: center;
  line-height: 1.4;
  font-weight: var(--font-weight-medium);
  min-height: 56rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.warn-btn--primary {
  background: var(--gradient-warm);
  color: var(--color-text-inverse);
  border-color: transparent;
  font-weight: var(--font-weight-semibold);
  box-shadow: var(--shadow-primary-sm);
}
.warn-btn--primary:active {
  transform: scale(0.96);
  box-shadow: none;
}
.press-scale-active {
  transform: scale(0.96);
}

/* ====================================================================
 * 4. 登录卡片（液态玻璃主容器）
 * ==================================================================== */
.login-card {
  position: relative;
  z-index: 5;
  margin: 0 var(--space-4);
  padding: var(--space-5) var(--space-4) var(--space-6);
  background: var(--glass-bg-light-4);
  border-radius: var(--radius-lg);
  border: var(--glass-border-strong);
  /* 多层阴影：顶部高光（玻璃折光）+ 环境光 + 关键光 */
  box-shadow:
    var(--glass-highlight),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.04),
    0 24rpx 48rpx rgba(229, 90, 43, 0.16),
    0 8rpx 16rpx rgba(229, 90, 43, 0.08);
  overflow: hidden;
}

/* 卡片顶部柔光带（液态玻璃"光顶"） */
.login-card__shine {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--gradient-shine);
  pointer-events: none;
  z-index: 1;
}

/* ====================================================================
 * 5. 登录 / 注册 Tab 切换（胶囊滑动指示器）
 * ==================================================================== */
.login-tabs {
  position: relative;
  display: flex;
  align-items: center;
  height: 72rpx;
  margin-bottom: var(--space-3);
  background: var(--color-bg-section);
  border-radius: var(--radius-pill);
  padding: 6rpx;
  box-sizing: border-box;
}

/* 胶囊指示器：绝对定位 + Spring 弹性（left 位移） */
.login-tabs__indicator {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: calc(50% - 12rpx);
  height: calc(100% - 12rpx);
  background: var(--gradient-warm);
  border-radius: var(--radius-pill);
  box-shadow:
    var(--shadow-orange-inset),
    var(--shadow-primary-sm);
  transition: left var(--duration-base) var(--ease-spring);
  z-index: 0;
  pointer-events: none;
}
/* 切换到"注册"时滑到右半边 */
.login-tabs__indicator--right {
  left: calc(50% + 6rpx);
}

.login-tab {
  position: relative;
  z-index: 1;
  flex: 1;
  text-align: center;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
  height: 60rpx;
  line-height: 60rpx;
  letter-spacing: 2rpx;
  transition: color var(--duration-base) var(--ease-out);
  min-height: 88rpx; /* 可访问性：≥ 44pt 触控热区 */
  display: flex;
  align-items: center;
  justify-content: center;
}
.login-tab--active {
  color: var(--color-text-inverse);
  font-weight: var(--font-weight-bold);
  font-size: var(--font-size-lg);
}

/* ====================================================================
 * 6. 输入框：浮动标签 + 底部边框 + focus 高亮
 * ==================================================================== */
.field {
  position: relative;
  padding: var(--space-4) 0 var(--space-2);
  margin-bottom: var(--space-2);
}
.field__label {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
  letter-spacing: 1rpx;
  margin-bottom: var(--space-1);
  line-height: var(--line-height-tight);
  transition: color var(--duration-fast) var(--ease-out);
}
.field--focus .field__label {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.field__input-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  min-height: 64rpx;
}
.field__input {
  flex: 1;
  display: block;
  width: 100%;
  font-size: var(--font-size-lg);
  color: var(--color-text-primary);
  background: transparent;
  border: none;
  padding: 0;
  height: 64rpx;
  line-height: 64rpx;
  font-weight: var(--font-weight-medium);
  letter-spacing: 1rpx;
}
.field__placeholder {
  color: var(--color-text-disabled);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-regular);
}
.field__line {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 2rpx;
  background: var(--color-bg-divider);
  transition: background var(--duration-fast) var(--ease-out);
}
/* focus 时光带：从中心展开（OriginOS 6 边缘光），位于 .field 底部 */
.field__line-active {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 0;
  height: 4rpx;
  background: var(--gradient-warm);
  border-radius: 4rpx;
  transform: translateX(-50%);
  transition: width var(--duration-base) var(--ease-spring),
              box-shadow var(--duration-base) var(--ease-out);
  pointer-events: none;
}
.field--focus .field__line {
  background: transparent;
}
.field--focus .field__line-active {
  width: 100%;
  box-shadow: 0 0 12rpx rgba(255, 107, 53, 0.4);
}

/* 密码可见切换 */
.field__toggle {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-circle);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--color-bg-section);
  border: var(--border-width) solid var(--color-bg-divider);
}
.field__toggle:active {
  transform: scale(0.94);
  background: var(--color-primary-soft);
}
.field__toggle-icon {
  width: 28rpx;
  height: 16rpx;
  border: 2rpx solid var(--color-text-secondary);
  border-radius: 6rpx;
  position: relative;
}
.field__toggle-icon::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 8rpx;
  border: 2rpx solid var(--color-text-secondary);
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
}
.field__toggle-icon::after {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 6rpx;
  background: var(--color-text-secondary);
  border-radius: 50%;
}
.field__toggle-icon--on::after {
  background: var(--color-primary);
  width: 12rpx;
  height: 6rpx;
  border-radius: 6rpx;
}

/* ====================================================================
 * 7. 协议勾选（玻璃感自定义 checkbox）
 *     底部 margin 设为 0，由 .primary-btn 的 margin-top 统一控制
 *     整体间距，避免"两边都留 margin"导致的累加空白
 * ==================================================================== */
.agreement {
  margin: var(--space-3) 0 0;
}
/* checkbox 整体：垂直居中对齐（让方框和文字 x-height 中心对正），
   间距紧凑（gap 8rpx 即可），去掉内边距让 .agreement 不再被"撑高" */
.checkbox {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  padding: 0;
  min-height: 88rpx; /* 可访问性 */
  cursor: pointer;
}
.checkbox__box {
  position: relative;
  width: 36rpx;
  height: 36rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-section);
  border: 2rpx solid var(--border-color-strong);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all var(--duration-base) var(--ease-spring);
  /* 不再 margin-top 偏移；改为 align-items: center 让方框和文字 x-height 居中对齐 */
}
.checkbox__check {
  width: 16rpx;
  height: 8rpx;
  border-left: 4rpx solid var(--color-text-inverse);
  border-bottom: 4rpx solid var(--color-text-inverse);
  transform: rotate(-45deg) scale(0);
  margin-top: -4rpx;
  transition: transform var(--duration-base) var(--ease-spring);
}
.checkbox--checked .checkbox__box {
  background: var(--gradient-warm);
  border-color: transparent;
  box-shadow: var(--shadow-primary-sm);
  transform: scale(1.05);
}
.checkbox--checked .checkbox__check {
  transform: rotate(-45deg) scale(1);
}
.checkbox--active .checkbox__box {
  transform: scale(0.92);
}
.checkbox__label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-base);
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}
.checkbox__link {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ====================================================================
 * 8. 主按钮：主色渐变 + 玻璃高光 + 阴影 + Spring 按下
 *     顶部 margin 减小 + padding: 0 + 隐藏 button 默认 ::after 占位
 *     避免 button 元素在 padding/margin 之外还偷偷增加额外空白
 * ==================================================================== */
.primary-btn {
  position: relative;
  margin: var(--space-2) 0 var(--space-2);
  /* 显式清零 button 元素的默认 padding，避免内容上移/多出空间 */
  padding: 0;
  background: var(--gradient-warm);
  color: var(--color-text-inverse);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  border-radius: var(--radius-pill);
  height: 96rpx;
  line-height: 96rpx;
  letter-spacing: 8rpx;
  /* 多层阴影 + 顶部白色高光（液态玻璃感） */
  box-shadow:
    var(--shadow-orange-inset),
    var(--shadow-primary-md);
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out),
              opacity var(--duration-fast) var(--ease-out);
  overflow: hidden;
  border: var(--glass-border-strong);
}
/* 按钮顶部光带（液态玻璃"光顶"） */
.primary-btn::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 20%;
  right: 20%;
  height: 2rpx;
  background: var(--gradient-shine);
  pointer-events: none;
  z-index: 1;
}
.primary-btn::after {
  /* 微信 button 元素的 ::after 默认是"边框层"，会占位并增加行高。
     这里显式关闭：去边框 + 去 content，避免按钮"上方多出空白"或"被撑大"。 */
  border: none;
  width: auto;
  height: auto;
  content: none;
}
.primary-btn--active,
.primary-btn:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: var(--shadow-orange-inset), var(--shadow-primary-sm);
  opacity: 0.95;
}
.primary-btn[disabled] {
  opacity: 0.5;
  background: var(--color-bg-section);
  color: var(--color-text-disabled);
  box-shadow: none;
  border-color: transparent;
}

/* ====================================================================
 * 9. 登录提示
 * ==================================================================== */
.login-tip {
  text-align: center;
  font-size: var(--font-size-xs);
  margin-top: var(--space-2);
  line-height: var(--line-height-base);
}

/* ====================================================================
 * 10. 分割线（左右渐隐 + 居中文字）
 * ==================================================================== */
.login-divider {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin: var(--space-5) 0 var(--space-3);
}
.login-divider__line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-color) 50%, transparent 100%);
}
.login-divider__text {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  letter-spacing: 2rpx;
}

/* ====================================================================
 * 11. 第三方登录图标（玻璃按钮 + SVG 图标）
 * ==================================================================== */
.third-party {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-5);
  padding: var(--space-2) 0;
}
.third-party__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;  /* 44pt 触控热区 */
  height: 88rpx;
  border-radius: var(--radius-circle);
  background: var(--glass-bg-light-4);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-sm);
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
  position: relative;
  overflow: hidden;
}
.third-party__btn--active,
.third-party__btn:active {
  transform: scale(0.94);
  box-shadow: var(--shadow-glass-sm), inset 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
}
.third-party__icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-circle);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
/* 微信：绿色 */
.third-party__icon--wechat {
  background: linear-gradient(135deg, #2DC97E 0%, #07C160 100%);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}
/* QQ：蓝色 */
.third-party__icon--qq {
  background: linear-gradient(135deg, #4FA8FF 0%, #2F80ED 100%);
  box-shadow: 0 4rpx 12rpx rgba(47, 128, 237, 0.3);
}
/* 手机号：橘色 */
.third-party__icon--phone {
  background: var(--gradient-warm);
  box-shadow: var(--shadow-primary-sm);
}

/* SVG 风格的内嵌图标（用 CSS 伪元素绘制，无 emoji） */
.icon-wechat {
  position: relative;
  width: 24rpx;
  height: 20rpx;
  background: var(--color-text-inverse);
  border-radius: 6rpx 6rpx 6rpx 0;
  transform: rotate(-8deg);
}
.icon-wechat::before,
.icon-wechat::after {
  content: '';
  position: absolute;
  background: #07C160;
  border-radius: 50%;
  width: 4rpx;
  height: 4rpx;
}
.icon-wechat::before { top: 6rpx; left: 4rpx; }
.icon-wechat::after  { top: 6rpx; right: 4rpx; }

.icon-qq {
  position: relative;
  width: 22rpx;
  height: 22rpx;
  background: var(--color-text-inverse);
  border-radius: 6rpx 6rpx 50% 50%;
  transform: rotate(45deg);
}
.icon-qq::before,
.icon-qq::after {
  content: '';
  position: absolute;
  background: #2F80ED;
  border-radius: 50%;
  width: 6rpx;
  height: 6rpx;
}
.icon-qq::before { top: -3rpx; left: 1rpx; }
.icon-qq::after  { top: -3rpx; right: 1rpx; }

.icon-phone {
  position: relative;
  width: 18rpx;
  height: 26rpx;
  background: var(--color-text-inverse);
  border-radius: 4rpx;
}
.icon-phone::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 50%;
}
.icon-phone::after {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 2rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* ====================================================================
 * 12. 入场动画（卡片从下方淡入 + 缩放）
 * ==================================================================== */
.anim-page {
  animation: pageIn var(--duration-slow) var(--ease-out) both;
}
@keyframes pageIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
.anim-fade {
  animation: fadeInUp var(--duration-base) var(--ease-out) both;
}
.anim-fade-down {
  animation: fadeInDown var(--duration-slow) var(--ease-out) both;
}
.anim-card-in {
  animation: cardIn var(--duration-slow) var(--ease-spring) 120ms both;
}
@keyframes fadeInUp {
  from { transform: translateY(16rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}
@keyframes fadeInDown {
  from { transform: translateY(-16rpx); opacity: 0; }
  to   { transform: translateY(0);      opacity: 1; }
}
@keyframes cardIn {
  from { transform: translateY(40rpx) scale(0.96); opacity: 0; }
  to   { transform: translateY(0)     scale(1);    opacity: 1; }
}

/* ====================================================================
 * 13. 可访问性：prefers-reduced-motion 关闭动效
 * ==================================================================== */
@media (prefers-reduced-motion: reduce) {
  .brand__halo,
  .brand__halo--2,
  .brand__logo-wrap,
  .anim-page,
  .anim-fade,
  .anim-fade-down,
  .anim-card-in,
  .anim-modal-in,
  .checkbox__check,
  .checkbox__box,
  .login-tabs__indicator,
  .field__line-active,
  .third-party__btn,
  .primary-btn,
  .field__label,
  .agreement-modal-mask,
  .agreement-modal {
    animation: none !important;
    transition: none !important;
  }
}

/* ====================================================================
 * 14. 协议同意弹窗（液态玻璃 + 风格统一 + Spring 弹入）
 *    设计思路：
 *    - 遮罩：半透黑 + 12rpx 模糊（iOS 风格毛玻璃）
 *    - 弹窗主体：复用 .card-glass 玻璃感 + 主色光晕图标
 *    - 关闭按钮：右上角圆形（玻璃感）
 *    - 标题/副标题：主色渐变文字
 *    - 协议条目：圆点 + 概要 + 完整链接
 *    - 底部双按钮：次按钮（玻璃） + 主按钮（渐变）
 * ==================================================================== */

/* 遮罩 */
.agreement-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(60, 30, 15, 0.45);
  /* iOS 风格 backdrop-filter */
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4);
  box-sizing: border-box;
  animation: agreementModalMaskIn 0.3s var(--ease-out) both;
}
@keyframes agreementModalMaskIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* 弹窗主体 */
.agreement-modal {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  /* 用 .card-glass 背景 + 圆角 + 阴影，与登录卡统一 */
  background: var(--glass-bg-light-4);
  border-radius: var(--radius-lg);
  border: var(--glass-border-strong);
  box-shadow:
    var(--glass-highlight),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 24rpx 64rpx rgba(229, 90, 43, 0.28),
    0 8rpx 24rpx rgba(229, 90, 43, 0.16);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
/* Spring 弹入：scale + translateY，弹性曲线 */
.anim-modal-in {
  animation: agreementModalIn 0.4s var(--ease-spring) both;
}
@keyframes agreementModalIn {
  from { transform: translateY(40rpx) scale(0.94); opacity: 0; }
  to   { transform: translateY(0)     scale(1);    opacity: 1; }
}

/* 顶部柔光带（和登录卡一致） */
.agreement-modal__shine {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--gradient-shine);
  pointer-events: none;
  z-index: 1;
}

/* 关闭按钮（右上角） */
.agreement-modal__close {
  position: absolute;
  top: var(--space-3);
  right: var(--space-3);
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-circle);
  background: var(--color-bg-section);
  border: var(--border-width) solid var(--color-bg-divider);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  transition: transform var(--duration-fast) var(--ease-spring),
              background var(--duration-fast) var(--ease-out);
}
.agreement-modal__close-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
}
/* 用 ::before / ::after 画 X */
.agreement-modal__close-icon::before,
.agreement-modal__close-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 3rpx;
  background: var(--color-text-secondary);
  border-radius: 2rpx;
  transform-origin: center;
}
.agreement-modal__close-icon::before {
  transform: translate(-50%, -50%) rotate(45deg);
}
.agreement-modal__close-icon::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* 头部：图标 + 标题 + 副标题 */
.agreement-modal__header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-6) var(--space-4) var(--space-4);
  text-align: center;
}
.agreement-modal__icon {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  margin-bottom: var(--space-3);
  display: flex;
  align-items: center;
  justify-content: center;
}
.agreement-modal__icon-ring {
  position: absolute;
  inset: 0;
  border-radius: var(--radius-circle);
  background: var(--gradient-warm);
  opacity: 0.18;
  animation: agreementModalRingPulse 2.4s var(--ease-in-out) infinite;
}
@keyframes agreementModalRingPulse {
  0%, 100% { transform: scale(1);   opacity: 0.18; }
  50%      { transform: scale(1.18); opacity: 0.32; }
}
/* 盾牌图标（CSS 绘制，禁 emoji，用户规则 5） */
.agreement-modal__icon-shield {
  position: relative;
  width: 44rpx;
  height: 50rpx;
  background: var(--gradient-warm);
  -webkit-mask: radial-gradient(circle at 50% 18%, transparent 12rpx, #000 12rpx) center/100% 100% no-repeat;
  border-radius: 22rpx 22rpx 24rpx 24rpx / 26rpx 26rpx 28rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.35);
}
.agreement-modal__icon-shield::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 18rpx;
  height: 9rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: translate(-50%, -65%) rotate(-45deg);
}

.agreement-modal__title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  letter-spacing: 2rpx;
  line-height: var(--line-height-tight);
  background: var(--gradient-warm);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: var(--space-2);
}
.agreement-modal__subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  letter-spacing: 1rpx;
  line-height: var(--line-height-base);
}

/* 正文：滚动区域 */
.agreement-modal__body {
  padding: 0 var(--space-4);
  overflow-y: auto;
  /* 避免和顶部 shine / 关闭按钮重叠 */
  flex: 1;
}
.agreement-modal__item {
  padding: var(--space-3) 0;
}
.agreement-modal__item-title {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-2);
  letter-spacing: 1rpx;
}
.agreement-modal__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-circle);
  flex-shrink: 0;
}
.agreement-modal__dot--user {
  background: var(--gradient-warm);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.15);
}
.agreement-modal__dot--privacy {
  background: linear-gradient(135deg, #4FA8FF 0%, #2F80ED 100%);
  box-shadow: 0 0 0 4rpx rgba(47, 128, 237, 0.15);
}
.agreement-modal__item-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-loose);
  letter-spacing: 0.5rpx;
  margin-bottom: var(--space-2);
}
.agreement-modal__link {
  display: inline-block;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  letter-spacing: 1rpx;
  padding: var(--space-1) 0;
}
.agreement-modal__divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--color-bg-divider) 50%, transparent 100%);
  margin: 0 var(--space-2);
}

/* 底部双按钮 */
.agreement-modal__footer {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom, 0));
  background: var(--color-bg-section);
  border-top: var(--border-width) solid var(--color-bg-divider);
}
.agreement-modal__btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--radius-pill);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  letter-spacing: 4rpx;
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
}
.agreement-modal__btn--secondary {
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
  border: var(--border-width) solid var(--color-bg-divider);
  box-shadow: var(--shadow-glass-sm);
}
.agreement-modal__btn--secondary:active {
  transform: scale(0.96);
  background: var(--color-bg-section);
}
.agreement-modal__btn--primary {
  background: var(--gradient-warm);
  color: var(--color-text-inverse);
  border: var(--glass-border-strong);
  box-shadow: var(--shadow-orange-inset), var(--shadow-primary-md);
}
.agreement-modal__btn--primary:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-orange-inset), var(--shadow-primary-sm);
  opacity: 0.95;
}

/* noop：阻止冒泡到 mask（用 .catchtap 也能实现，这里给个显式空函数） */
.noop {}

/* ====================================================================
 * 15. 完整协议详情弹窗（液态玻璃 + 风格统一 + 滚动正文）
 *    设计要点：
 *    - 复用 .agreement-modal 的视觉语言（玻璃感 + 主色渐变标题）
 *    - 高度比同意弹窗更高（max-height: 88vh），让用户有更多阅读空间
 *    - 用 scroll-view 显示章节化协议，支持原生滚动 + 隐藏滚动条
 *    - 章节标题用主色文字，段落用次要文字颜色
 * ==================================================================== */

/* 遮罩（与同意弹窗同款） */
.agreement-detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(60, 30, 15, 0.45);
  z-index: 210; /* 高于同意弹窗（200），避免层叠问题 */
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3);
  box-sizing: border-box;
  animation: agreementModalMaskIn 0.3s var(--ease-out) both;
}

/* 弹窗主体 */
.agreement-detail {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  max-height: 88vh;
  background: var(--glass-bg-light-4);
  border-radius: var(--radius-lg);
  border: var(--glass-border-strong);
  box-shadow:
    var(--glass-highlight),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 32rpx 80rpx rgba(229, 90, 43, 0.32),
    0 12rpx 32rpx rgba(229, 90, 43, 0.18);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 顶部柔光带 */
.agreement-detail__shine {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--gradient-shine);
  pointer-events: none;
  z-index: 1;
}

/* 关闭按钮（与同意弹窗同款 X） */
.agreement-detail__close {
  position: absolute;
  top: var(--space-3);
  right: var(--space-3);
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-circle);
  background: var(--color-bg-section);
  border: var(--border-width) solid var(--color-bg-divider);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  transition: transform var(--duration-fast) var(--ease-spring),
              background var(--duration-fast) var(--ease-out);
}
.agreement-detail__close:active {
  transform: scale(0.92);
  background: var(--color-primary-soft);
}
.agreement-detail__close-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
}
.agreement-detail__close-icon::before,
.agreement-detail__close-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 3rpx;
  background: var(--color-text-secondary);
  border-radius: 2rpx;
  transform-origin: center;
}
.agreement-detail__close-icon::before {
  transform: translate(-50%, -50%) rotate(45deg);
}
.agreement-detail__close-icon::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* 头部：标题 + 更新时间 */
.agreement-detail__header {
  padding: var(--space-5) var(--space-4) var(--space-3);
  padding-right: 88rpx; /* 避开关闭按钮 */
  text-align: center;
  border-bottom: var(--border-width) solid var(--color-bg-divider);
  background: linear-gradient(180deg, var(--color-bg-section) 0%, transparent 100%);
}
.agreement-detail__title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  letter-spacing: 2rpx;
  line-height: var(--line-height-tight);
  background: var(--gradient-warm);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: var(--space-1);
}
.agreement-detail__meta {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  letter-spacing: 1rpx;
}

/* 正文：scroll-view 区域 */
.agreement-detail__body {
  flex: 1;
  padding: var(--space-4) var(--space-4) 0;
  /* 兼容性：iOS 平滑滚动 */
  -webkit-overflow-scrolling: touch;
}

/* 章节 */
.agreement-detail__section {
  margin-bottom: var(--space-4);
}
.agreement-detail__section-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  letter-spacing: 1rpx;
  line-height: var(--line-height-base);
  margin-bottom: var(--space-2);
  padding-left: var(--space-2);
  border-left: 4rpx solid var(--color-primary);
}
.agreement-detail__paragraph {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-loose);
  letter-spacing: 0.5rpx;
  margin-bottom: var(--space-2);
  /* 段落首行缩进 2 字，符合中文阅读习惯 */
  text-indent: 2em;
}
/* 段落中"严禁/禁止"等警示行的特殊样式：如果有需要，可加 .danger 类手动标记 */

/* 滚动区底部留白，避免最后一段被底部按钮挡住 */
.agreement-detail__footer-spacer {
  height: var(--space-4);
}

/* 底部"我已知晓"按钮 */
.agreement-detail__footer {
  padding: var(--space-3) var(--space-4);
  padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom, 0));
  background: var(--color-bg-section);
  border-top: var(--border-width) solid var(--color-bg-divider);
}
.agreement-detail__btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--radius-pill);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  letter-spacing: 4rpx;
  background: var(--gradient-warm);
  color: var(--color-text-inverse);
  border: var(--glass-border-strong);
  box-shadow: var(--shadow-orange-inset), var(--shadow-primary-md);
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
}
.agreement-detail__btn:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-orange-inset), var(--shadow-primary-sm);
  opacity: 0.95;
}
