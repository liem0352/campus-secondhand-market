/* pages/detail/detail.wxss
   商品详情页样式 v3 —— 校园易物（融合设计系统重构版）
   --------------------------------------------------------------------
   设计语言：Apple Liquid Glass + MD3 Expressive + OriginOS 6 空间光学
   关键 token：颜色 / 字号 / 间距 / 圆角 / 阴影 / 动效 全部来自 app.wxss
   实现要点：
     1) 液态玻璃（半透 + 顶部高光 + 多层阴影 + 边缘内发光）
     2) Spring 弹性动效（cubic-bezier(0.34, 1.56, 0.64, 1)）
     3) 光感设计（光圈 / 渐变光带 / 环境光）
     4) 严格使用 var(--*) token，**严禁硬编码颜色**
     5) 触达目标 ≥ 88rpx；支持 prefers-reduced-motion */

/* ============ 页面基线 ============ */
.detail-page {
  padding-bottom: 0; /* 底部 CTA 自带安全区 */
  background: var(--gradient-page);
  min-height: 100vh;
}

/* 页面入场动画：从右滑入 + 渐显 */
.detail-page.detail-page--enter {
  animation: detail-page-enter 0.45s var(--ease-spring) both;
}

@keyframes detail-page-enter {
  0%   { transform: translateX(60rpx); opacity: 0; }
  100% { transform: translateX(0);     opacity: 1; }
}

/* ============ 1. 顶部自定义导航栏 ============ */
.detail-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: var(--z-fixed);
  background: transparent;
  transition: background var(--duration-base) var(--ease-out),
              box-shadow var(--duration-base) var(--ease-out),
              border-color var(--duration-base) var(--ease-out);
  border-bottom: 2rpx solid transparent;
}

.detail-nav--scrolled {
  background: var(--glass-bg-light-3);
  border-bottom-color: var(--border-color-light);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  /* 顶部白色高光 + 多层阴影（Liquid Glass 模拟） */
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.6),
    0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.detail-nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-2) var(--space-3);
  height: 88rpx;
}

.detail-nav__title {
  flex: 1;
  text-align: center;
  color: var(--color-text-inverse);
  letter-spacing: 0.5rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 0 var(--space-3);
  transition: color var(--duration-base) var(--ease-out);
}

.detail-nav__title--dark {
  color: var(--color-text-primary);
}

.detail-nav__right {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

/* 玻璃感按钮（圆形 + 半透 + 高光） */
.detail-nav__btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-circle);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--glass-bg-light-1);
  border: 2rpx solid var(--glass-border-light);
  /* 顶部白色高光 + 柔和阴影 */
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5),
    0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform var(--duration-fast) var(--ease-spring),
              background var(--duration-fast) var(--ease-out);
}

.detail-nav__btn--glass {
  background: rgba(255, 255, 255, 0.35);
  border-color: rgba(255, 255, 255, 0.45);
}

.detail-nav__btn--pressed {
  background: rgba(255, 255, 255, 0.55);
  transform: scale(0.92);
}

.detail-nav__icon {
  width: 32rpx;
  height: 32rpx;
}

/* ============ 2. 主图轮播 ============ */
.banner-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--color-bg-hover);
  overflow: hidden;
  /* 顶部高光带（光感） */
  background: linear-gradient(180deg, #fff8f1 0%, #ffe4d4 100%);
}

.banner {
  width: 100%;
  height: 100%;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  background: var(--gradient-warm-soft);
  color: var(--color-text-inverse);
  font-size: 200rpx;
  font-weight: var(--font-weight-extrabold);
  font-family: var(--font-family-display);
}

/* 玻璃感指示器：底部小条 + 计数器 */
.banner-indicator {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: 0 var(--space-3);
}

.banner-indicator__track {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--glass-bg-dark-1);
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: var(--shadow-glass-sm);
}

.banner-indicator__dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: var(--radius-circle);
  background: rgba(255, 255, 255, 0.45);
  transition: width var(--duration-base) var(--ease-spring),
              background var(--duration-base) var(--ease-out);
}

.banner-indicator__dot--active {
  width: 22rpx;
  background: var(--color-text-inverse);
}

.banner-indicator__counter {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-pill);
  background: var(--glass-bg-dark-1);
  color: var(--color-text-inverse);
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}

/* 右上角热度徽标（玻璃 chip） */
.detail-banner__badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 5;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  background: var(--glass-bg-dark-2);
  color: var(--color-text-inverse);
  border-radius: var(--radius-pill);
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18),
    0 6rpx 20rpx rgba(0, 0, 0, 0.18);
  font-size: 22rpx;
  font-weight: var(--font-weight-medium);
  letter-spacing: 0.5rpx;
}

.detail-banner__badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-circle);
  background: #FFD66B;
  box-shadow: 0 0 8rpx rgba(255, 214, 107, 0.7);
  animation: anim-pulse 1.4s var(--ease-in-out) infinite;
}

.detail-banner__badge--anim {
  animation: detail-badge-fade 0.5s 0.3s var(--ease-out) both;
}

.detail-banner__badge-num {
  font-size: 28rpx;
  font-weight: var(--font-weight-extrabold);
  color: #FFD66B;
  font-family: var(--font-family-mono);
  font-variant-numeric: tabular-nums;
}

.detail-banner__badge-eye {
  opacity: 0.85;
}

@keyframes detail-badge-fade {
  0%   { transform: translateY(-10rpx); opacity: 0; }
  100% { transform: translateY(0);      opacity: 1; }
}

/* ============ 3. 价格区（光感渐变） ============ */
.price-section {
  position: relative;
  background: var(--gradient-soft);
  padding: var(--space-5) var(--space-4) var(--space-3);
  margin: 0;
  overflow: hidden;
  /* 顶部白色高光（玻璃折光） */
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
}

.price-section__ambient {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: var(--radius-circle);
  background: radial-gradient(circle, rgba(255, 138, 92, 0.45) 0%, transparent 70%);
  pointer-events: none;
}

.price-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: wrap;
  gap: var(--space-3);
  position: relative;
  z-index: 1;
}

.price-main-wrap {
  display: inline-flex;
  align-items: baseline;
  gap: 4rpx;
  font-family: var(--font-family-mono);
  font-variant-numeric: tabular-nums;
  background: var(--gradient-warm);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: var(--color-primary);
  filter: drop-shadow(0 2rpx 6rpx rgba(255, 107, 53, 0.18));
}

.price-currency {
  color: var(--color-primary);
  font-size: var(--font-size-xl);
  -webkit-text-fill-color: var(--color-primary);
}

.price-main {
  font-size: 56rpx;
  font-weight: var(--font-weight-extrabold);
  line-height: 1;
  color: var(--color-primary);
  -webkit-text-fill-color: var(--color-primary);
}

/* 玻璃感原价 chip */
.price-original-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-pill);
  background: var(--glass-bg-light-3);
  border: 2rpx solid var(--glass-border-light);
  box-shadow: var(--shadow-glass-sm);
}

.price-original-chip__label {
  color: var(--color-text-tertiary);
}

.price-original-chip__val {
  color: var(--color-text-secondary);
  text-decoration: line-through;
  font-family: var(--font-family-mono);
  font-variant-numeric: tabular-nums;
}

/* 折扣 chip（主色光感） */
.price-discount {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary-soft);
  color: var(--color-primary);
  box-shadow: var(--shadow-primary-sm);
}

.price-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-3);
  position: relative;
  z-index: 1;
}

.price-meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.55);
  color: var(--color-text-secondary);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.price-meta-pill__dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: var(--radius-circle);
  background: var(--color-success);
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.18);
}

/* ============ 4. 标题 + 标签（玻璃卡） ============ */
.title-section {
  position: relative;
  margin: var(--space-3) var(--space-3) 0;
  padding: var(--space-4);
  border-radius: var(--radius-md);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
}

.title-section__highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.8) 50%, transparent 100%);
  pointer-events: none;
}

.title-text {
  display: block;
  color: var(--color-text-primary);
  line-height: var(--line-height-snug);
  margin-bottom: var(--space-2);
  font-weight: var(--font-weight-bold);
  letter-spacing: 0.5rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
}

/* 标签依次入场（Spring 弹性） */
.tag__anim {
  animation: tag-pop 0.4s var(--ease-spring) both;
  animation-delay: var(--tag-stagger, 0ms);
}

@keyframes tag-pop {
  0%   { transform: scale(0.6); opacity: 0; }
  60%  { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1);   opacity: 1; }
}

/* ============ 5. 商品描述（玻璃卡） ============ */
.description-card {
  position: relative;
  margin: var(--space-3);
  padding: var(--space-4);
  border-radius: var(--radius-md);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

.card-title {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
  letter-spacing: 0.5rpx;
}

.description-text {
  color: var(--color-text-primary);
  white-space: pre-wrap;
  word-break: break-word;
  display: block;
  line-height: var(--line-height-loose);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-5);
  margin-top: var(--space-3);
  padding-top: var(--space-3);
  border-top: 2rpx solid var(--color-bg-divider);
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.meta-label {
  line-height: 1;
}

.meta-value {
  color: var(--color-text-primary);
  line-height: 1.2;
  font-weight: var(--font-weight-semibold);
}

/* ============ 6. 信任保障区（玻璃 3 列） ============ */
.trust-bar {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  margin: var(--space-3);
  padding: var(--space-4);
  border-radius: var(--radius-md);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
}

.trust-bar__highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.8) 50%, transparent 100%);
  pointer-events: none;
}

.trust-item {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-2);
  min-width: 0;
}

.trust-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-base);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
}

.trust-img {
  width: 32rpx;
  height: 32rpx;
}

.trust-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
  flex: 1;
}

.trust-title {
  color: var(--color-text-primary);
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.trust-desc {
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.trust-divider {
  width: 2rpx;
  background: var(--color-bg-divider);
  margin: 0 var(--space-2);
  align-self: stretch;
}

/* ============ 7. 卖家卡（玻璃感 + 信用分） ============ */
.seller-card {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-3);
  margin: var(--space-3);
  padding: var(--space-4);
  border-radius: var(--radius-md);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
  /* 必要时信用分/关注按钮换行，避免挤压用户名 */
  flex-wrap: wrap;
  row-gap: var(--space-2);
}

.seller-card__highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.8) 50%, transparent 100%);
  pointer-events: none;
}

.avatar-placeholder {
  background: var(--color-primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xl);
}

/* 卖家信息区：保证最小宽度，避免被右侧信用徽章/按钮挤到一字一行 */
.seller-meta {
  /* flex: 1 1 auto + min-width 200rpx 让文字区至少有足够宽度横向显示 */
  flex: 1 1 auto;
  min-width: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  /* 给用户信息一个合理上限，避免超长用户名把整体拉变形 */
  max-width: 100%;
}

/* 用户名 / 学校：禁止中文按字换行，超出用省略号 */
.seller-name,
.seller-school {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.seller-name {
  color: var(--color-text-primary);
  line-height: 1.2;
  font-weight: var(--font-weight-bold);
}

.seller-school {
  line-height: 1.2;
}

/* ============ 8. 用户评价（玻璃卡） ============ */
.reviews-section {
  position: relative;
  margin: var(--space-3);
  padding: var(--space-4);
  border-radius: var(--radius-md);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
}

.reviews-section__highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.8) 50%, transparent 100%);
  pointer-events: none;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.card-head-left {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  min-width: 0;
}

.rating-summary {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.rating-num {
  font-family: var(--font-family-mono);
  font-variant-numeric: tabular-nums;
}

.rating-stars {
  display: inline-flex;
  gap: 2rpx;
  color: var(--color-text-disabled);
  font-size: var(--font-size-sm);
  letter-spacing: 1rpx;
}

.rating-star--on {
  color: #FFB84D;
  text-shadow: 0 1rpx 4rpx rgba(255, 184, 77, 0.4);
}

.card-link {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 8rpx;
  border-radius: var(--radius-pill);
  transition: background var(--duration-fast) var(--ease-out);
}

.card-link:active {
  background: var(--color-bg-hover);
}

.reviews-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.review-item {
  display: flex;
  flex-direction: row;
  gap: var(--space-2);
  padding: var(--space-3);
  background: var(--color-bg-page);
  border-radius: var(--radius-base);
  border: 2rpx solid var(--color-bg-divider);
}

.review-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-circle);
  background: var(--color-primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-base);
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  flex-shrink: 0;
  overflow: hidden;
}

.review-body {
  flex: 1;
  min-width: 0;
}

.review-meta {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: 4rpx;
}

.review-name {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
}

.review-stars {
  display: inline-flex;
  gap: 2rpx;
  color: var(--color-text-disabled);
  font-size: var(--font-size-xs);
  letter-spacing: 1rpx;
}

.review-star--on {
  color: #FFB84D;
}

.review-time {
  margin-left: auto;
}

.review-content {
  color: var(--color-text-primary);
  display: block;
  line-height: var(--line-height-base);
}

.review-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: var(--space-1);
}

.review-tag {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 10rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary-softer);
  color: var(--color-primary);
  font-size: var(--font-size-xs);
  line-height: 1.4;
}

.reviews-empty {
  text-align: center;
  padding: var(--space-4) 0;
}

/* ============ 9. 价格趋势（玻璃卡 + 柱状图） ============ */
.price-trend {
  position: relative;
  margin: var(--space-3);
  padding: var(--space-4);
  border-radius: var(--radius-md);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
}

.price-trend__highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.8) 50%, transparent 100%);
  pointer-events: none;
}

.price-trend__avg {
  display: inline-flex;
  align-items: baseline;
  gap: 6rpx;
}

.price-trend__avg-val {
  color: var(--color-primary);
  font-family: var(--font-family-mono);
  font-variant-numeric: tabular-nums;
}

.price-trend__chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--space-1);
  margin: var(--space-3) 0;
  height: 180rpx;
  padding: var(--space-2) 0;
}

.price-trend__bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.price-trend__bar {
  width: 70%;
  border-radius: var(--radius-sm);
  /* 顶部白色高光 */
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.4);
  transition: opacity var(--duration-fast) var(--ease-out);
}

.price-trend__bar {
  animation: price-bar-grow 0.6s var(--ease-out) both;
  animation-delay: var(--bar-stagger, 0ms);
  transform-origin: bottom;
}

@keyframes price-bar-grow {
  0%   { transform: scaleY(0.05); opacity: 0.4; }
  100% { transform: scaleY(1);    opacity: 1;   }
}

.price-trend__label {
  line-height: 1;
}

.price-trend__meta {
  display: flex;
  justify-content: space-between;
  gap: var(--space-2);
  padding-top: var(--space-3);
  border-top: 2rpx solid var(--color-bg-divider);
}

.price-trend__tag {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  align-items: center;
}

/* ============ 10. 相似推荐（横滑） ============ */
.similar-section {
  margin: var(--space-3) 0;
  padding: 0 var(--space-3);
}

.section-head {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.section-bar {
  width: 8rpx;
  height: 28rpx;
  border-radius: var(--radius-pill);
  background: var(--gradient-warm);
  box-shadow: var(--shadow-primary-sm);
}

.section-title {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
  letter-spacing: 0.5rpx;
}

.section-meta {
  margin-left: auto;
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

.similar-scroll {
  white-space: nowrap;
  width: 100%;
}

.similar-inner {
  display: inline-flex;
  flex-direction: row;
  gap: var(--space-2);
  padding-bottom: var(--space-2);
}

.similar-card {
  position: relative;
  width: 240rpx;
  display: inline-flex;
  flex-direction: column;
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-glass-sm);
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
  flex-shrink: 0;
}

.similar-card--pressed {
  transform: scale(0.97);
  box-shadow: var(--shadow-sm);
}

.similar-cover {
  width: 100%;
  height: 240rpx;
}

.similar-body {
  padding: var(--space-2);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.similar-name {
  color: var(--color-text-primary);
  display: block;
  line-height: 1.3;
  font-weight: var(--font-weight-medium);
}

.similar-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

.similar-price {
  color: var(--color-primary);
  font-family: var(--font-family-mono);
  font-variant-numeric: tabular-nums;
  font-weight: var(--font-weight-bold);
}

.similar-views {
  font-size: var(--font-size-xs);
}

/* ============ 11. 同校在售 ============ */
.same-school {
  margin: var(--space-3);
}

.same-school__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.same-school__item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-2);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-glass-sm);
  transition: transform var(--duration-fast) var(--ease-spring),
              background var(--duration-fast) var(--ease-out);
}

.same-school__item--pressed {
  transform: scale(0.98);
  background: var(--glass-bg-light-4);
}

.same-school__item {
  animation: same-school-in 0.4s var(--ease-spring) both;
}

.same-school__item:nth-child(1) { animation-delay: 0.05s; }
.same-school__item:nth-child(2) { animation-delay: 0.15s; }
.same-school__item:nth-child(3) { animation-delay: 0.25s; }

@keyframes same-school-in {
  0%   { transform: translateX(20rpx); opacity: 0; }
  100% { transform: translateX(0);     opacity: 1; }
}

.same-school__cover {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-base);
  flex-shrink: 0;
}

.same-school__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.same-school__name {
  color: var(--color-text-primary);
  display: block;
  line-height: 1.3;
  font-weight: var(--font-weight-medium);
}

.same-school__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

.same-school__price {
  color: var(--color-primary);
  font-family: var(--font-family-mono);
  font-variant-numeric: tabular-nums;
  font-weight: var(--font-weight-bold);
}

/* ============ 12. 举报入口 ============ */
.report-link {
  text-align: center;
  padding: var(--space-4) 0;
  letter-spacing: 1rpx;
  transition: opacity var(--duration-fast) var(--ease-out);
}

.report-link:active {
  opacity: 0.5;
}

/* ============ 13. 底部留白（避免 CTA 遮挡） ============ */
.bottom-spacer {
  height: 200rpx;
}

/* ============ 14. 底部固定 CTA Bar（液态玻璃） ============ */
.cta-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-3);
  padding-bottom: calc(env(safe-area-inset-bottom) + var(--space-2));
  background: var(--glass-bg-light-4);
  border-top: 2rpx solid var(--glass-border-light);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.8),
    0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  overflow: hidden;
}

.cta-bar__highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 107, 53, 0.4) 50%, transparent 100%);
}

.cta-icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  /* 加宽到 112rpx：56rpx 圆形 + 4rpx gap + 至少 40rpx 文字宽度 + 12rpx 缓冲 */
  min-width: 112rpx;
  min-height: 88rpx;
  padding: var(--space-1);
  border-radius: var(--radius-base);
  flex-shrink: 0;
  gap: 4rpx;
  transition: background var(--duration-fast) var(--ease-out);
}

.cta-icon-btn__circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-circle);
  background: var(--glass-bg-light-3);
  border: 2rpx solid var(--glass-border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-glass-sm);
  transition: background var(--duration-fast) var(--ease-out),
              box-shadow var(--duration-fast) var(--ease-out);
}

.cta-icon-btn__circle--active {
  background: var(--color-primary-soft);
  border-color: rgba(255, 107, 53, 0.4);
  box-shadow: var(--shadow-primary-sm);
}

.cta-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 文字禁止按字换行（一字一行） */
.cta-icon-text {
  color: var(--color-text-secondary);
  line-height: 1;
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  letter-spacing: 0;
}

.cta-btn-half {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-md);
  letter-spacing: 1rpx;
}

/* ============ 加载 / 空态 ============ */
.loading-mask {
  position: fixed;
  inset: 0;
  background: var(--gradient-page);
  z-index: var(--z-modal);
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-5) var(--space-8);
  border-radius: var(--radius-md);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-primary-soft);
  border-top-color: var(--color-primary);
  border-radius: var(--radius-circle);
  animation: spin 0.8s linear infinite;
}

.empty-state {
  padding: 200rpx 0;
}

/* ============ 区块顺序入场（Spring 弹性 + stagger） ============ */
.detail-section__anim {
  animation: detail-section-in 0.5s var(--ease-spring) both;
}

.detail-section__anim--2 { animation-delay: 0.08s; }
.detail-section__anim--3 { animation-delay: 0.16s; }
.detail-section__anim--4 { animation-delay: 0.24s; }
.detail-section__anim--5 { animation-delay: 0.32s; }
.detail-section__anim--6 { animation-delay: 0.40s; }

@keyframes detail-section-in {
  0%   { transform: translateY(24rpx); opacity: 0; }
  100% { transform: translateY(0);     opacity: 1; }
}

/* 主图渐入 + 装饰徽标 */
.detail-banner__anim {
  animation: detail-banner-in 0.6s var(--ease-out) both;
}

@keyframes detail-banner-in {
  0%   { transform: scale(1.04); opacity: 0; }
  100% { transform: scale(1);    opacity: 1; }
}

/* ============ 可访问性：尊重 prefers-reduced-motion ============ */
@media (prefers-reduced-motion: reduce) {
  .detail-page.detail-page--enter,
  .detail-section__anim,
  .detail-banner__anim,
  .detail-banner__badge--anim,
  .tag__anim,
  .price-trend__bar,
  .same-school__item {
    animation: none !important;
    transition: none !important;
  }
}
