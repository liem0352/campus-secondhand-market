/* pages/index/index.wxss
 * --------------------------------------------------------------------
 * 校园易物 · 首页样式（v5 融合设计）
 * 设计语言：Apple Liquid Glass + MD3 Expressive + OriginOS 6 光感
 * 全部数值通过 var(--*) 引用 design token（app.wxss 已定义）
 * 严禁硬编码颜色 / 字号 / 间距；严禁使用 emoji 图标
 */

/* ============== 页面容器（暖白渐变底） ============== */
.home-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  /* 底部预留 tab-bar + 安全区（与 app.wxss 的 .page-wrap 配合） */
  padding-bottom: 180rpx;
}

/* ============== 顶部安全区占位 ============== */
.home-safe-top {
  width: 100%;
}

/* ============== 自定义导航栏（透明 + 沉浸式）
   高度 64rpx = 32px，与微信原生胶囊按钮同高，确保垂直方向完美对齐
   标题脱离 flex 流，绝对定位到屏幕中央，不受 padding-right 不对称影响 ============== */
.home-navbar {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  /* space-between 让左右按钮分别贴到 navbar 两端，标题用 absolute 居中到屏幕中央 */
  justify-content: space-between;
  /* 左右 padding 都为 0，由内联样式动态控制 padding-right（让出胶囊位置） */
  padding: 0;
  height: 64rpx;
  margin-top: var(--space-2);
}

.home-navbar__left {
  /* 左侧保留基础视觉边距，避免贴到屏幕最左边 */
  margin-left: var(--space-4);
}

.home-navbar__left,
.home-navbar__right {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-circle);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-sm);
  transition: transform var(--duration-fast) var(--ease-spring),
              background var(--duration-fast) var(--ease-out);
  flex-shrink: 0;
}

.home-navbar__btn--pressed,
.home-navbar__left:active,
.home-navbar__right:active {
  transform: scale(0.92);
  background: var(--glass-bg-light-4);
}

.home-navbar__icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

.home-navbar__title {
  /* 绝对定位：脱离 flex 流，居中到屏幕中央（不受 padding 不对称影响） */
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  letter-spacing: 2rpx;
  background: var(--gradient-warm);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  white-space: nowrap;
  /* 标题只是展示，不需要拦截点击事件，避免遮挡左右按钮 */
  pointer-events: none;
}

.home-navbar__dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-error);
  box-shadow: 0 0 0 3rpx var(--color-bg-card);
  animation: home-navbar-pulse 1.6s var(--ease-in-out) infinite;
}

@keyframes home-navbar-pulse {
  0%, 100% { transform: scale(1);   opacity: 1; }
  50%      { transform: scale(1.2); opacity: 0.7; }
}

/* ============== Hero 渐变 Banner（液态玻璃） ==============
   多层光晕 + 顶部高光 + 多层阴影
*/
.home-hero {
  position: relative;
  margin: var(--space-2) var(--space-4) var(--space-3);
  padding: var(--space-4) var(--space-4) calc(var(--space-4) + 36rpx);
  background: var(--gradient-warm);
  border-radius: var(--radius-2xl);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  /* 液态玻璃多层阴影：环境光 + 关键光 + 顶部白色高光 */
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2),
    var(--shadow-primary-lg);
  color: var(--color-text-inverse);
  overflow: hidden;
}

/* Hero 装饰光晕层（3 层呼吸光） */
.home-hero__halo {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.home-hero__halo--1 {
  width: 260rpx;
  height: 260rpx;
  top: -100rpx;
  right: -80rpx;
  background: rgba(255, 255, 255, 0.18);
  filter: blur(16rpx);
}

.home-hero__halo--2 {
  width: 180rpx;
  height: 180rpx;
  bottom: -60rpx;
  left: -40rpx;
  background: rgba(255, 255, 255, 0.12);
  filter: blur(14rpx);
}

.home-hero__halo--3 {
  width: 140rpx;
  height: 140rpx;
  top: 50%;
  right: 35%;
  background: rgba(255, 255, 255, 0.1);
  filter: blur(20rpx);
  animation: halo-breathe 4.5s var(--ease-in-out) infinite;
}

@keyframes halo-breathe {
  0%, 100% { transform: scale(1)   translate(-50%, -50%); opacity: 0.5; }
  50%      { transform: scale(1.4) translate(-50%, -50%); opacity: 0.9; }
}

/* Hero 装饰星星：闪烁（OriginOS 增强光） */
.home-hero__star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: var(--color-text-inverse);
  border-radius: 50%;
  pointer-events: none;
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.85);
  animation: star-twinkle 2.4s var(--ease-in-out) infinite;
}
.home-hero__star--1 { top: 36rpx;  right: 220rpx; animation-delay: 0s; }
.home-hero__star--2 { top: 120rpx; right: 80rpx;  animation-delay: 0.8s; width: 6rpx;  height: 6rpx; }
.home-hero__star--3 { top: 200rpx; right: 280rpx; animation-delay: 1.6s; width: 10rpx; height: 10rpx; }

@keyframes star-twinkle {
  0%, 100% { transform: scale(0.6); opacity: 0.4; }
  50%      { transform: scale(1.4); opacity: 1;   }
}

.home-hero__head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.home-hero__brand {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

/* Logo 圆形玻璃底 */
.home-hero__logo-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-circle);
  background: rgba(255, 255, 255, 0.25);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.6),
    0 4rpx 12rpx rgba(204, 77, 34, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  backdrop-filter: blur(6rpx);
}

.home-hero__logo {
  width: 56rpx;
  height: 56rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(204, 77, 34, 0.25));
}

.home-hero__greet {
  display: flex;
  flex-direction: column;
}

.home-hero__hello {
  font-size: 44rpx;
  font-weight: var(--font-weight-extrabold);
  line-height: var(--line-height-tight);
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 12rpx rgba(204, 77, 34, 0.18);
}

.home-hero__sub {
  margin-top: 4rpx;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  letter-spacing: 2rpx;
  opacity: 0.92;
}

/* Hero 统计数据（玻璃胶囊） */
.home-hero__stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.22);
  border-radius: var(--radius-pill);
  padding: 12rpx 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5),
    0 2rpx 8rpx rgba(229, 90, 43, 0.15);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.home-hero__stats--pressed,
.home-hero__stats:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.32);
}

.home-hero__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}

.home-hero__stat-num {
  font-size: 28rpx;
  font-weight: var(--font-weight-extrabold);
  line-height: 1.1;
  letter-spacing: 1rpx;
}

.home-hero__stat-label {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  opacity: 0.88;
  line-height: 1.2;
  margin-top: 2rpx;
}

.home-hero__stat-divider {
  width: 2rpx;
  height: 32rpx;
  background: rgba(255, 255, 255, 0.4);
  margin: 0 var(--space-1);
}

/* ============== 搜索框（玻璃感胶囊） ============== */
.home-search__box {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 var(--space-2) 0 var(--space-3);
  margin-top: var(--space-3);
  background: rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-pill);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  /* 多层阴影：玻璃高光 + 主色光晕 */
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 1),
    0 8rpx 20rpx rgba(229, 90, 43, 0.2),
    0 2rpx 6rpx rgba(229, 90, 43, 0.1);
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
}

.home-search__box--pressed,
.home-search__box:active {
  transform: scale(0.98);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 1),
    0 4rpx 12rpx rgba(229, 90, 43, 0.24);
}

.home-search__icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-right: var(--space-2);
  opacity: 0.6;
}

.home-search__placeholder {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  line-height: 1;
}

.home-search__hot-tag {
  flex-shrink: 0;
  margin-left: var(--space-2);
  padding: 2rpx 12rpx;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  background: var(--color-primary-soft);
  border-radius: var(--radius-pill);
  letter-spacing: 1rpx;
}

.home-search__divider {
  width: 2rpx;
  height: 28rpx;
  background: var(--color-bg-divider);
  margin: 0 var(--space-2);
  flex-shrink: 0;
}

.home-search__mic-btn {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-circle);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-soft);
  transition: transform var(--duration-fast) var(--ease-spring),
              background var(--duration-fast) var(--ease-out);
}

.home-search__mic-btn--pressed,
.home-search__mic-btn:active {
  transform: scale(0.9);
  background: var(--color-primary);
}

.home-search__mic {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.85;
}

.home-search__mic-btn--pressed .home-search__mic,
.home-search__mic-btn:active .home-search__mic {
  filter: brightness(0) invert(1);
}

/* ============== 快捷入口（玻璃圆形按钮） ============== */
.home-quick {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  margin: 0 var(--space-3);
  padding: var(--space-3) var(--space-2);
  background: var(--glass-bg-light-3);
  border-radius: var(--radius-lg);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  backdrop-filter: blur(8rpx);
}

.home-quick__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: var(--space-1) var(--space-2);
  min-height: 88rpx;
  justify-content: center;
  transition: transform var(--duration-fast) var(--ease-spring);
}

.home-quick__item--pressed,
.home-quick__item:active {
  transform: scale(0.92);
}

.home-quick__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-circle);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-1);
  position: relative;
  transition: transform var(--duration-fast) var(--ease-spring);
}

.home-quick__icon-inner {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-circle);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.home-quick__img {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
  opacity: 0.95;
}

.home-quick__label {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  line-height: 1.2;
  margin-top: 2rpx;
}

/* ============== 公告滚动条（玻璃横条） ============== */
.home-notice {
  display: flex;
  align-items: center;
  margin: var(--space-3) var(--space-3) 0;
  padding: 0 var(--space-3);
  height: 64rpx;
  background: var(--glass-bg-light-3);
  border-radius: var(--radius-pill);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-sm);
  transition: opacity var(--duration-fast) var(--ease-out),
              transform var(--duration-fast) var(--ease-spring);
}

.home-notice--pressed,
.home-notice:active {
  opacity: 0.85;
  transform: scale(0.99);
}

.home-notice__tag {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 12rpx;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-inverse);
  background: var(--gradient-warm);
  border-radius: var(--radius-sm);
  margin-right: var(--space-2);
  line-height: 1;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 53, 0.3);
}

.home-notice__tag-icon {
  width: 20rpx;
  height: 20rpx;
  filter: brightness(0) invert(1);
}

.home-notice__swiper {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  overflow: hidden;
}

.home-notice__title {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 64rpx;
}

.home-notice__arrow {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  border-right: 2rpx solid var(--color-text-tertiary);
  border-top: 2rpx solid var(--color-text-tertiary);
  transform: rotate(45deg);
  margin-left: var(--space-2);
  opacity: 0.6;
}

/* ============== 轮播图（玻璃卡） ============== */
.home-banner {
  margin: var(--space-3) var(--space-3) 0;
}

.home-banner__swiper {
  height: 240rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.home-banner__item {
  height: 240rpx;
  padding: 0 6rpx;
  box-sizing: border-box;
}

.home-banner__card {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  padding: 0 var(--space-5);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.home-banner__content {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  color: var(--color-text-inverse);
}

.home-banner__title {
  font-size: 36rpx;
  font-weight: var(--font-weight-extrabold);
  line-height: 1.2;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.12);
}

.home-banner__subtitle {
  margin-top: 8rpx;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  opacity: 0.92;
  line-height: 1.4;
}

.home-banner__cta {
  margin-top: var(--space-2);
  align-self: flex-start;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  padding: 6rpx 18rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: var(--radius-pill);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
  letter-spacing: 1rpx;
}

/* 装饰光圈：双层 */
.home-banner__deco {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.home-banner__deco--1 {
  right: -60rpx;
  top: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.18);
  filter: blur(8rpx);
}

.home-banner__deco--2 {
  right: 80rpx;
  bottom: -80rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.12);
  filter: blur(10rpx);
}

.home-banner__dots {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: var(--space-2);
  gap: 12rpx;
}

.home-banner__dot {
  width: 12rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--color-border);
  transition: all var(--duration-fast) var(--ease-out);
}

.home-banner__dot--active {
  width: 32rpx;
  background: var(--color-primary);
  box-shadow: 0 0 8rpx rgba(255, 107, 53, 0.4);
}

/* ============== 通用区块标题 ============== */
.home-section__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: var(--space-4) var(--space-3) var(--space-2);
}

.home-section__title {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.2;
}

.home-section__bar {
  width: 6rpx;
  height: 28rpx;
  background: var(--gradient-warm);
  border-radius: 3rpx;
  box-shadow: 0 0 8rpx rgba(255, 107, 53, 0.4);
}

.home-section__bar--flash {
  background: var(--gradient-coral);
  box-shadow: 0 0 8rpx rgba(255, 77, 79, 0.4);
}

.home-section__bar--deals {
  background: linear-gradient(180deg, #07C160 0%, #04A050 100%);
  box-shadow: 0 0 8rpx rgba(7, 193, 96, 0.4);
}

.home-section__flash-title {
  background: linear-gradient(90deg, #FF4D4F, #FF7A45);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  font-weight: var(--font-weight-extrabold);
}

.home-section__sub {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-left: 6rpx;
  font-weight: var(--font-weight-regular);
}

.home-section__more {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--glass-bg-light-3);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-sm);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.home-section__more--pressed,
.home-section__more:active {
  transform: scale(0.94);
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.home-section__more--flash {
  color: #FF4D4F;
  font-weight: var(--font-weight-semibold);
}

/* 倒计时 */
.home-countdown {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-left: 12rpx;
}

.home-countdown__label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-right: 4rpx;
}

.home-countdown__box {
  min-width: 36rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-inverse);
  background: linear-gradient(180deg, #2C2C2C 0%, #1A1A1A 100%);
  border-radius: 6rpx;
  padding: 0 6rpx;
  font-family: var(--font-family-mono);
}

.home-countdown__sep {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-extrabold);
  color: var(--color-text-primary);
}

/* ============== 限时特惠 ============== */
.home-flash {
  width: 100%;
}

.home-flash__scroll {
  width: 100%;
  white-space: nowrap;
}

.home-flash__inner {
  display: inline-flex;
  flex-direction: row;
  padding: 0 var(--space-3) var(--space-2);
  gap: var(--space-2);
}

.home-flash__card {
  width: 280rpx;
  flex-shrink: 0;
  background: var(--glass-bg-light-3);
  border-radius: var(--radius-md);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
}

.home-flash__card--pressed,
.home-flash__card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-primary-sm);
}

.home-flash__cover {
  position: relative;
  width: 100%;
  height: 240rpx;
  background: var(--color-bg-section);
  overflow: hidden;
}

.home-flash__cover image {
  width: 100%;
  height: 100%;
  display: block;
}

.home-flash__cover-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFE5DA 0%, #FFCEB8 100%);
  color: var(--color-primary);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  text-align: center;
  padding: 0 var(--space-2);
}

.home-flash__ribbon {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 10rpx;
  background: linear-gradient(90deg, #FF4D4F, #FF7A45);
  color: var(--color-text-inverse);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 6rpx rgba(255, 77, 79, 0.4);
  z-index: 2;
}

.home-flash__body {
  padding: 12rpx var(--space-2);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.home-flash__name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.home-flash__price-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.home-flash__price {
  font-size: 30rpx;
  font-weight: var(--font-weight-extrabold);
  color: #FF4D4F;
  font-family: var(--font-family-mono);
}

.home-flash__origin {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  text-decoration: line-through;
}

.home-flash__bar {
  position: relative;
  width: 100%;
  height: 8rpx;
  background: var(--color-bg-section);
  border-radius: 4rpx;
  overflow: hidden;
}

.home-flash__bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF7A45 0%, #FF4D4F 100%);
  border-radius: 4rpx;
  transition: width var(--duration-slow) var(--ease-out);
}

.home-flash__sold {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* shine 扫光 */
.home-flash__shine {
  position: absolute;
  top: 0;
  left: -120rpx;
  width: 80rpx;
  height: 100%;
  background: var(--gradient-shine);
  transform: skewX(-20deg);
  animation: shine-sweep 3.5s var(--ease-in-out) infinite;
  pointer-events: none;
  z-index: 1;
}

@keyframes shine-sweep {
  0%        { left: -120rpx; }
  60%, 100% { left: 320rpx; }
}

/* ============== 近期成交（玻璃卡） ============== */
.home-deals {
  margin: 0 var(--space-3) var(--space-3);
  background: var(--glass-bg-light-3);
  border-radius: var(--radius-md);
  border: var(--glass-border-light);
  padding: var(--space-3) var(--space-3) var(--space-2);
  box-shadow: var(--shadow-glass-md);
}

.home-deals__list {
  display: flex;
  flex-direction: column;
}

.home-deals__item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) 0;
  border-bottom: 2rpx solid var(--color-bg-divider);
  transition: background var(--duration-fast) var(--ease-out);
}

.home-deals__item:last-child {
  border-bottom: none;
}

.home-deals__avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE5DA 0%, #FFCEB8 100%);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 53, 0.2);
}

.home-deals__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.home-deals__text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-deals__product {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-deals__price {
  font-size: 26rpx;
  font-weight: var(--font-weight-bold);
  color: #FF4D4F;
  font-family: var(--font-family-mono);
  flex-shrink: 0;
}

/* ============== 热门商品横滑 ============== */
.home-hot {
  width: 100%;
}

.home-hot__scroll {
  width: 100%;
  white-space: nowrap;
}

.home-hot__inner {
  display: inline-flex;
  flex-direction: row;
  padding: 0 var(--space-3) var(--space-2);
  gap: var(--space-2);
}

.home-hot__card {
  width: 240rpx;
  flex-shrink: 0;
  background: var(--glass-bg-light-3);
  border-radius: var(--radius-md);
  border: var(--glass-border-light);
  box-shadow: var(--shadow-glass-md);
  overflow: hidden;
  transition: transform var(--duration-fast) var(--ease-spring);
}

.home-hot__card--pressed,
.home-hot__card:active {
  transform: scale(0.97);
}

.home-hot__cover {
  position: relative;
  width: 100%;
  height: 240rpx;
  background: var(--color-bg-section);
}

.home-hot__cover image {
  width: 100%;
  height: 100%;
}

.home-hot__cover-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-align: center;
  background: linear-gradient(135deg, #FFE5DA 0%, #FFD4BD 100%);
}

.home-hot__badge {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-inverse);
  background: rgba(0, 0, 0, 0.55);
  border-radius: var(--radius-pill);
  backdrop-filter: blur(4rpx);
  font-weight: var(--font-weight-medium);
}

.home-hot__body {
  padding: var(--space-2);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.home-hot__name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  white-space: normal;
}

.home-hot__price {
  font-size: 26rpx;
  font-weight: var(--font-weight-extrabold);
  color: var(--color-primary);
  line-height: 1.2;
}

/* ============== 一级分类横滑（玻璃 chip） ============== */
.home-cats {
  white-space: nowrap;
  padding: var(--space-2) 0;
  background: transparent;
}

.home-cats__inner {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  padding: 0 var(--space-2);
}

.home-cats__item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  flex-shrink: 0;
  padding: var(--space-2);
  border-radius: var(--radius-md);
  min-height: 88rpx;
  transition: background-color var(--duration-fast) var(--ease-out),
              transform var(--duration-fast) var(--ease-spring);
}

.home-cats__item--pressed,
.home-cats__item:active {
  background: var(--color-primary-softer);
  transform: scale(0.96);
}

.home-cats__icon {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-circle);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-1);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.home-cats__icon-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--color-primary-soft) 0%, var(--color-primary-softer) 100%);
}

.home-cats__icon-img {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  z-index: 1;
  opacity: 0.85;
}

.home-cats__label {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: 1.2;
  text-align: center;
  font-weight: var(--font-weight-medium);
}

/* ============== 双列瀑布流容器 ============== */
.home-grid {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding: 0 var(--space-3);
  gap: var(--space-2);
}

.home-grid__col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.home-grid__item {
  width: 100%;
  margin-bottom: var(--space-3);
}

/* ============== 骨架屏 ============== */
.skeleton {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(90deg,
    var(--color-bg-section) 0%,
    var(--color-bg-hover) 50%,
    var(--color-bg-section) 100%);
  background-size: 200% 100%;
  animation: skeleton-shine 1.4s var(--ease-in-out) infinite;
  margin-bottom: var(--space-3);
}

.skeleton--alt {
  height: 440rpx;
}

@keyframes skeleton-shine {
  0%   { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

/* ============== 通用空 / 错误状态 ============== */
.home-state {
  width: 100%;
  padding: var(--space-12) var(--space-6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.home-state__icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.85;
  margin-bottom: var(--space-4);
}

.home-state__title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-2);
}

.home-state__desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: var(--line-height-base);
  margin-bottom: var(--space-4);
}

.home-state__btn {
  min-width: 280rpx;
}

/* ============== 底部加载状态 ============== */
.home-footer {
  padding: var(--space-4) var(--space-3);
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
}

.home-footer__loading {
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.home-footer__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  opacity: 0.4;
  animation: footer-dot 1.2s var(--ease-in-out) infinite;
}

.home-footer__dot:nth-child(2) { animation-delay: 0.15s; }
.home-footer__dot:nth-child(3) { animation-delay: 0.3s; }

@keyframes footer-dot {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40%           { transform: scale(1);   opacity: 1;   }
}

.home-footer__end {
  display: flex;
  align-items: center;
  width: 100%;
  gap: var(--space-3);
}

.home-footer__line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--color-bg-divider) 50%, transparent 100%);
}

/* ====================================================================
 * 装饰 / 动效 增强
 * ==================================================================== */

/* Hero 渐入 + 浮动光晕 */
.home-hero__anim {
  animation: hero-fade-in 0.6s var(--ease-out) both;
}

@keyframes hero-fade-in {
  0%   { transform: translateY(-20rpx); opacity: 0; }
  100% { transform: translateY(0);      opacity: 1; }
}

/* 搜索框：浮动入场 + 弹性曲线 */
.home-search__anim {
  animation: search-slide-up 0.5s 0.2s var(--ease-spring) both;
}

@keyframes search-slide-up {
  0%   { transform: translateY(20rpx); opacity: 0; }
  100% { transform: translateY(0);     opacity: 1; }
}

/* 快捷入口：错落微动效（stagger 0-180ms） */
.home-quick__anim {
  animation: quick-pop 0.5s var(--ease-spring) both;
  animation-delay: var(--quick-stagger, 0ms);
}

@keyframes quick-pop {
  0%   { transform: scale(0.8) translateY(10rpx); opacity: 0; }
  60%  { transform: scale(1.05) translateY(-2rpx); opacity: 1; }
  100% { transform: scale(1) translateY(0); opacity: 1; }
}

/* 分类横滑：错落滑入 */
.home-cats__anim {
  animation: cat-slide 0.4s var(--ease-out) both;
  animation-delay: var(--cat-stagger, 0ms);
}

@keyframes cat-slide {
  0%   { transform: translateY(12rpx); opacity: 0; }
  100% { transform: translateY(0);     opacity: 1; }
}

/* 限时特惠：整块渐入 + 卡片依次进入 */
.flash__anim {
  animation: section-fade-in 0.5s 0.1s var(--ease-out) both;
}

@keyframes section-fade-in {
  0%   { transform: translateY(20rpx); opacity: 0; }
  100% { transform: translateY(0);     opacity: 1; }
}

.flash-card__anim {
  animation: flash-card-pop 0.4s var(--ease-spring) both;
  animation-delay: var(--flash-stagger, 0ms);
}

@keyframes flash-card-pop {
  0%   { transform: translateY(20rpx) scale(0.96); opacity: 0; }
  60%  { transform: translateY(-4rpx) scale(1.02); opacity: 1; }
  100% { transform: translateY(0)     scale(1);    opacity: 1; }
}

/* 倒计时数字：每秒脉冲（光感增强） */
.countdown-pulse {
  animation: countdown-pulse 1s var(--ease-in-out) infinite;
}

@keyframes countdown-pulse {
  0%, 100% { transform: scale(1);    box-shadow: 0 0 0 0 rgba(217, 54, 62, 0); }
  50%      { transform: scale(1.06); box-shadow: 0 0 0 4rpx rgba(217, 54, 62, 0.18); }
}

/* 近期成交：整块渐入 + 列表项依次滑入 */
.deals__anim {
  animation: section-fade-in 0.5s 0.15s var(--ease-out) both;
}

.deals-item__anim {
  animation: deals-item-slide 0.4s var(--ease-out) both;
  animation-delay: var(--deals-stagger, 0ms);
}

@keyframes deals-item-slide {
  0%   { transform: translateX(-20rpx); opacity: 0; }
  100% { transform: translateX(0);      opacity: 1; }
}

/* 商品卡片：交错入场（左列早于右列 20ms，row 40ms） */
.pcard__anim {
  animation: pcard-rise 0.45s var(--ease-spring) both;
  animation-delay: var(--pcard-stagger, 0ms);
}

@keyframes pcard-rise {
  0%   { transform: translateY(24rpx); opacity: 0; }
  100% { transform: translateY(0);     opacity: 1; }
}

/* 热门商品：错落微动效 */
.home-hot__card {
  animation: hot-rise 0.4s var(--ease-spring) both;
  animation-delay: var(--hot-stagger, 0ms);
}

@keyframes hot-rise {
  0%   { transform: translateY(12rpx) scale(0.97); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

/* ====================================================================
 * 可访问性：尊重 prefers-reduced-motion
 * ==================================================================== */
@media (prefers-reduced-motion: reduce) {
  .home-hero__anim,
  .home-search__anim,
  .home-quick__anim,
  .home-cats__anim,
  .flash__anim,
  .flash-card__anim,
  .deals__anim,
  .deals-item__anim,
  .pcard__anim,
  .home-hot__card,
  .home-flash__shine,
  .countdown-pulse,
  .home-navbar__dot,
  .home-hero__star,
  .home-hero__halo--3 {
    animation: none !important;
  }
}
