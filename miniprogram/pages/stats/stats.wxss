/* pages/stats/stats.wxss — 统计页面样式（校园易物橘色主题 v2）
 * --------------------------------------------------------------------
 * 主题色：#FF6B35 活力橘
 * 替换范围：原"家庭记账"蓝主题（#1677ff / #4096ff / #bae0ff 等）
 * 视觉关键词：橘色 K 线 + 橘色柱图 + 橘色折线
 */

.container {
  padding: 20rpx 24rpx 160rpx;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff6b35;
  line-height: 1;
}

.empty {
  text-align: center;
  color: #bfbfbf;
  padding: 60rpx 0;
  font-size: 26rpx;
}

/* 月份选择器 */
.month-picker {
  display: flex;
  align-items: center;
  padding: 8rpx 0 24rpx;
}
.month-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}
.month-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  letter-spacing: 1rpx;
}
.month-arrow {
  width: 32rpx;
  height: 32rpx;
  color: #bfbfbf;
  line-height: 1;
}

/* KPI 三宫格：消费 / 收入 / 余额 */
.kpi {
  display: flex;
  gap: 16rpx;
}
.kpi-item {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  text-align: center;
}
.kpi-title {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}
.kpi-value {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  font-family: DIN, 'Helvetica Neue', sans-serif;
}
/* 支出：红（error 语义保留） */
.kpi-expense { background: linear-gradient(135deg, #fff2f0 0%, #ffd6d2 100%); }
.kpi-expense .kpi-value { color: #ff4d4f; }
/* 收入：绿（success 语义保留） */
.kpi-income  { background: linear-gradient(135deg, #f0fff5 0%, #d6f5e3 100%); }
.kpi-income  .kpi-value { color: #07c160; }
/* 余额：橘（品牌主色） */
.kpi-balance { background: linear-gradient(135deg, #fff2eb 0%, #ffe5da 100%); }
.kpi-balance .kpi-value { color: #ff6b35; }

/* ============ 饼图布局 ============ */
.pie-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.pie-canvas-wrap {
  width: 280rpx;
  height: 280rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pie-canvas {
  width: 280rpx;
  height: 280rpx;
  display: block;
}
.pie-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-width: 0;
  max-height: 280rpx;
  overflow-y: auto;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.legend-info {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}
.legend-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.legend-meta {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  font-family: DIN, sans-serif;
}

/* ============ 折线图（橘色） ============ */
.line-canvas {
  display: block;
}
.line-summary {
  display: flex;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.line-stat {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
}
.line-stat:last-child { border-right: none; }
.line-stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}
.line-stat-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ff6b35;
  font-family: DIN, sans-serif;
}

/* ============ 柱状图 ============ */
.bar-canvas {
  display: block;
}

/* ============ 成员贡献（CSS 列表） ============ */
.bar-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}
.bar-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.bar-name {
  width: 110rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bar-track {
  flex: 1;
  height: 22rpx;
  background: #f5f5f5;
  border-radius: 22rpx;
  overflow: hidden;
  position: relative;
}
.bar-fill {
  height: 100%;
  border-radius: 22rpx;
  background: linear-gradient(90deg, #ffb087 0%, #ff6b35 100%);
  transition: width 0.6s ease;
}
.bar-amount {
  width: 130rpx;
  font-size: 24rpx;
  color: #ff6b35;
  font-weight: 600;
  text-align: right;
  font-family: DIN, sans-serif;
  flex-shrink: 0;
}
