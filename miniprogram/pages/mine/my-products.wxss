/* 我的发布 / 我买到的 列表页样式 */
.myprods-page {
  min-height: 100vh;
  background: var(--color-bg-page, #F5F5F7);
  padding-bottom: 32rpx;
}

.myprods-tabs {
  display: flex;
  margin: 24rpx;
  padding: 8rpx 12rpx;
  border-radius: 16rpx;
  gap: 4rpx;
}

.myprods-tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
  padding: 18rpx 0;
  border-radius: 12rpx;
  position: relative;
  transition: all 0.2s;
}

.myprods-tab--active {
  background: linear-gradient(120deg, #FF6B35 0%, #FF8A5B 100%);
  color: #fff;
  font-weight: 600;
}

.myprods-tab__badge {
  position: absolute;
  top: 4rpx;
  right: 12rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  font-size: 18rpx;
  background: #FF4D4F;
  color: #fff;
  border-radius: 14rpx;
  padding: 0 6rpx;
}

.myprods-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.myprods-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fff;
}

.myprods-item__cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  flex-shrink: 0;
}

.myprods-item__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.myprods-item__title {
  font-size: 28rpx;
  color: var(--color-text-primary, #1F2937);
  line-height: 1.4;
}

.myprods-item__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.myprods-item__price {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B35;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999px;
  line-height: 1.2;
}

.status-badge--success { background: rgba(16, 185, 129, 0.12); color: #10B981; }
.status-badge--warning { background: rgba(245, 158, 11, 0.12); color: #F59E0B; }
.status-badge--info    { background: rgba(99, 102, 241, 0.12); color: #6366F1; }
.status-badge--cancelled { background: rgba(156, 163, 175, 0.12); color: #9CA3AF; }

.myprods-item__sub {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary, #9CA3AF);
}

.myprods-item__actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-end;
  justify-content: center;
  flex-shrink: 0;
}

.myprods-item__action {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #F3F4F6;
  color: var(--color-text-primary, #1F2937);
}

.myprods-item__action--danger {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.loading-more {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-tertiary, #9CA3AF);
  padding: 32rpx 0;
}
