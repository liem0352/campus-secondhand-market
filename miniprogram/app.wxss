/* ====================================================================
 * 9. 头像 / 徽章 / 标签
 * ==================================================================== */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-circle);
  background: var(--color-primary-soft);
  overflow: hidden;
  flex-shrink: 0;
}
.avatar-sm { width: 56rpx; height: 56rpx; }
.avatar-md { width: 80rpx; height: 80rpx; }
.avatar-lg { width: 120rpx; height: 120rpx; }
.avatar-xl { width: 160rpx; height: 160rpx; }

.tag {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 var(--space-2);
  border-radius: var(--radius-pill);
  font-size: var(--font-size-xs);
  background: var(--color-bg-divider);
  color: var(--color-text-secondary);
  line-height: 1;
  letter-spacing: 0.5rpx;
}
.tag-primary { background: var(--color-primary-soft); color: var(--color-primary); }
.tag-success { background: var(--color-success-soft); color: var(--color-success); }
.tag-warning { background: var(--color-warning-soft); color: var(--color-warning); }
.tag-error { background: var(--color-error-soft); color: var(--color-error); }
.tag-info { background: var(--color-info-soft); color: var(--color-info); }

/* 信用分徽章（业务专属） */
.credit-badge {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 var(--space-2);
  border-radius: var(--radius-pill);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  line-height: 1;
  letter-spacing: 0.5rpx;
}
.credit-high { background: var(--color-success-soft); color: var(--color-credit-high); }
.credit-mid  { background: var(--color-warning-soft); color: var(--color-credit-mid); }
.credit-low  { background: var(--color-error-soft); color: var(--color-credit-low); }

/* ====================================================================
 * 10. Spring 弹性动效 + 关键帧
 * --------------------------------------------------------------
 * 提供可复用的微交互类：
 *   - press-scale：按压缩放（通用）
 *   - press-depress：按下时下沉（深按反馈）
 *   - press-glow：按下时光晕增强（光感反馈）
 *   - hover-lift：悬停时上浮（光感浮起）
 * ==================================================================== */
.press-scale {
  transition: transform var(--duration-fast) var(--ease-spring);
}
.press-scale:active {
  transform: scale(0.96);
}

.press-depress {
  transition: transform var(--duration-fast) var(--ease-spring);
}
.press-depress:active {
  transform: scale(0.94) translateY(2rpx);
}

.press-glow {
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-fast) var(--ease-out);
}
.press-glow:active {
  transform: scale(0.96);
  box-shadow: 0 0 0 8rpx rgba(255, 107, 53, 0.12);
}

.hover-lift {
  transition: transform var(--duration-base) var(--ease-spring),
              box-shadow var(--duration-base) var(--ease-out);
}
.hover-lift:hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
}

/* ====================================================================
 * 11. 通用动画
 * ==================================================================== */
@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes fade-in-up {
  from { transform: translateY(16rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}
@keyframes fade-in-down {
  from { transform: translateY(-16rpx); opacity: 0; }
  to   { transform: translateY(0);      opacity: 1; }
}
@keyframes slide-up {
  from { transform: translateY(24rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}
@keyframes slide-down {
  from { transform: translateY(-24rpx); opacity: 0; }
  to   { transform: translateY(0);      opacity: 1; }
}
@keyframes scale-in {
  from { transform: scale(0.92); opacity: 0; }
  to   { transform: scale(1);    opacity: 1; }
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%      { opacity: 0.5; }
}
@keyframes breathe {
  0%, 100% { transform: scale(1);   opacity: 0.6; }
  50%      { transform: scale(1.2); opacity: 1; }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes twinkle {
  0%, 100% { transform: scale(0.6); opacity: 0.4; }
  50%      { transform: scale(1.4); opacity: 1; }
}
@keyframes shine-sweep {
  0%        { left: -120%; }
  60%, 100% { left: 220%; }
}

/* ====================================================================
 * 11.1 融合体系 v2 关键帧动画（新增 fusion-ui-design Part 22）
 * ==================================================================== */

/* iOS 26 Liquid Glass 折射光斑扫过 */
@keyframes liquid-specular-sweep {
  0%        { transform: translateX(-100%) skewX(-15deg); opacity: 0; }
  20%       { opacity: 1; }
  60%       { transform: translateX(200%) skewX(-15deg); opacity: 0.6; }
  100%      { transform: translateX(220%) skewX(-15deg); opacity: 0; }
}
.anim-liquid-shine {
  position: relative;
  overflow: hidden;
}
.anim-liquid-shine::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 60%;
  height: 100%;
  background: var(--liquid-specular);
  animation: liquid-specular-sweep 3s var(--ease-m3-spatial-default) infinite;
  pointer-events: none;
}

/* MagicOS 10 一镜到底转场（页面切换无缝衔接） */
@keyframes seamless-morph {
  0%   { transform: scale(1) translateY(0); opacity: 1; border-radius: var(--radius-md); }
  60%  { transform: scale(1.04) translateY(-8rpx); opacity: 0.9; border-radius: var(--radius-lg); }
  100% { transform: scale(1) translateY(0); opacity: 1; border-radius: var(--radius-md); }
}
.anim-seamless {
  animation: seamless-morph var(--duration-spring-slow) var(--ease-magicos-seamless) both;
}

/* OriginOS 6 陀螺仪光影（左→右扫过） */
@keyframes gyro-light-sweep {
  0%   { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.gyro-light {
  background-image: linear-gradient(115deg,
    transparent 0%,
    rgba(255, 255, 255, 0) 30%,
    rgba(255, 255, 255, 0.5) 50%,
    rgba(255, 255, 255, 0) 70%,
    transparent 100%);
  background-size: 200% 100%;
  background-repeat: no-repeat;
  animation: gyro-light-sweep 4s var(--ease-in-out) infinite;
}

/* Nothing OS 3.5 点阵跳动（点阵字符刷新） */
@keyframes dot-flicker {
  0%, 100% { opacity: 0.2; }
  20%      { opacity: 1; }
  40%      { opacity: 0.6; }
  60%      { opacity: 1; }
  80%      { opacity: 0.4; }
}
.anim-dot-flicker { animation: dot-flicker 1.2s steps(5, end) infinite; }

/* Nothing OS 点阵扫描 */
@keyframes dot-scan {
  0%   { background-position: 0 0; }
  100% { background-position: 0 100%; }
}
.anim-dot-scan {
  background-image: radial-gradient(circle at center, var(--color-text-primary) 1rpx, transparent 1.5rpx);
  background-size: 6rpx 6rpx;
  animation: dot-scan 1.5s steps(8, end) infinite;
}

/* Pixel UI / Material 3 Expressive 弹性入场 */
@keyframes m3-spatial-in {
  0%   { transform: scale(0.85) translateY(8rpx); opacity: 0; }
  60%  { transform: scale(1.02) translateY(-2rpx); opacity: 1; }
  100% { transform: scale(1) translateY(0); opacity: 1; }
}
.anim-m3-spatial-in { animation: m3-spatial-in var(--duration-spring-base) var(--ease-m3-spatial-fast) both; }

/* ColorOS 16 充电岛能量波扩散 */
@keyframes charge-wave {
  0%   { transform: scaleY(0.3); opacity: 0.6; }
  50%  { transform: scaleY(1); opacity: 1; }
  100% { transform: scaleY(0.3); opacity: 0.6; }
}
.anim-charge-wave {
  transform-origin: bottom center;
  animation: charge-wave 1.4s var(--ease-magicos-capsule) infinite;
}

/* One UI 9 Now Bar 渐变擦除进入 */
@keyframes oneui-reveal {
  0%   { clip-path: inset(0 100% 0 0); opacity: 0; }
  60%  { clip-path: inset(0 0 0 0); opacity: 1; }
  100% { clip-path: inset(0 0 0 0); opacity: 1; }
}
.anim-oneui-reveal { animation: oneui-reveal var(--duration-spring-base) var(--ease-oneui-smooth) both; }

/* MagicOS 10 灵动胶囊出现（圆→胶囊→卡片） */
@keyframes smart-capsule-in {
  0%   { width: 72rpx; height: 72rpx; border-radius: 50%; opacity: 0; transform: scale(0.5); }
  40%  { width: 96rpx; height: 72rpx; border-radius: 36rpx; opacity: 1; transform: scale(1.05); }
  100% { width: 200rpx; height: 72rpx; border-radius: 36rpx; opacity: 1; transform: scale(1); }
}
.anim-capsule-in { animation: smart-capsule-in var(--duration-spring-base) var(--ease-magicos-capsule) both; }

/* 频谱岛波形（MagicOS 10 音乐频谱） */
@keyframes spectrum-bar {
  0%, 100% { transform: scaleY(0.3); }
  50%      { transform: scaleY(1); }
}
.anim-spectrum {
  transform-origin: center;
  animation: spectrum-bar 0.8s var(--ease-in-out) infinite;
}
.anim-spectrum-1 { animation-delay: 0s; }
.anim-spectrum-2 { animation-delay: 0.15s; }
.anim-spectrum-3 { animation-delay: 0.3s; }
.anim-spectrum-4 { animation-delay: 0.45s; }
.anim-spectrum-5 { animation-delay: 0.6s; }

/* 3D 深度锁屏视差（HarmonyOS 7 特色） */
@keyframes parallax-depth {
  0%   { transform: translate3d(0, 0, 0) scale(1); }
  50%  { transform: translate3d(-4rpx, -2rpx, 0) scale(1.02); }
  100% { transform: translate3d(0, 0, 0) scale(1); }
}
.anim-parallax { animation: parallax-depth 6s var(--ease-in-out) infinite; }

/* OriginOS 6 渐进模糊 */
@keyframes progressive-blur-anim {
  0%   { filter: blur(0rpx); }
  100% { filter: blur(16rpx); }
}
.anim-progressive-blur-in {
  animation: progressive-blur-anim var(--duration-spring-base) var(--ease-magicos-seamless) both;
}

/* 倒计时环（MagicOS 10 计时器岛） */
@keyframes countdown-ring {
  0%   { stroke-dashoffset: 0; }
  100% { stroke-dashoffset: var(--ring-circumference, 220); }
}
.anim-countdown-ring {
  animation: countdown-ring var(--countdown-duration, 60s) linear both;
}

/* 数据流入（统计图表用） */
@keyframes data-flow {
  0%   { transform: translateY(100%); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}
.anim-data-flow {
  animation: data-flow var(--duration-spring-base) var(--ease-m3-spatial-default) both;
}

/* 数字滚动（iOS 弹簧数字） */
@keyframes number-roll {
  0%   { transform: translateY(100%); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}
.anim-number-roll {
  display: inline-block;
  animation: number-roll var(--duration-spring-base) var(--ease-m3-spatial-default) both;
}

/* 加载旋转（ColorOS 16 干脆利落） */
@keyframes loader-coloros {
  0%   { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
.anim-loader-coloros { animation: loader-coloros 0.8s var(--ease-coloros-quick) infinite; }

/* 弥散光按钮反馈（按下时 OriginOS 6 弥散光） */
@keyframes diffuse-flash {
  0%   { box-shadow: 0 0 0 0 rgba(255, 107, 53, 0.4); }
  100% { box-shadow: 0 0 0 24rpx rgba(255, 107, 53, 0); }
}
.anim-diffuse-flash:active {
  animation: diffuse-flash 0.6s var(--ease-out) both;
}

/* 渐显光带（页面顶部 hero 渐显） */
@keyframes hero-shimmer {
  0%   { opacity: 0; transform: translateY(-20rpx); }
  100% { opacity: 1; transform: translateY(0); }
}
.anim-hero-shimmer { animation: hero-shimmer var(--duration-spring-slow) var(--ease-m3-spatial-default) both; }

/* 错落列表入场（增强版） */
.anim-stagger-in {
  animation: bounce-in var(--duration-spring-base) var(--ease-origin-spring) both;
  animation-delay: var(--stagger-delay, 0ms);
}

/* 弹性出现 / 消失（OriginOS 6 风格） */
.bounce-in {
  animation: bounce-in var(--duration-spring-base) var(--ease-origin-spring) both;
}
@keyframes bounce-in {
  0%   { opacity: 0; transform: scale(0.5) translateY(20rpx); }
  60%  { opacity: 1; transform: scale(1.05) translateY(-4rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

.anim-fade { animation: fade-in var(--duration-base) var(--ease-out) both; }
.anim-fade-up { animation: fade-in-up var(--duration-base) var(--ease-out) both; }
.anim-fade-down { animation: fade-in-down var(--duration-base) var(--ease-out) both; }
.anim-slide-up { animation: slide-up var(--duration-slow) var(--ease-out) both; }
.anim-scale-in { animation: scale-in var(--duration-base) var(--ease-spring) both; }
.anim-spin { animation: spin 1s linear infinite; }
.anim-pulse { animation: pulse 2s var(--ease-in-out) infinite; }
.anim-breathe { animation: breathe 3s var(--ease-in-out) infinite; }

/* ==============================================================
 * 10.5 v2 Spring Motion 工具类（融合十一大体系）
 * --------------------------------------------------------------
 * 用法：直接添加到元素上即可获得对应体系的弹性动效
 * ============================================================== */

/* MD3 Expressive 6 套 spring 工具类 */
.spring-m3-fast     { transition: all var(--duration-spring-fast)    var(--ease-m3-spatial-fast); }
.spring-m3-default  { transition: all var(--duration-spring-base)    var(--ease-m3-spatial-default); }
.spring-m3-slow     { transition: all var(--duration-spring-slow)    var(--ease-m3-spatial-slow); }
.spring-m3-effects  { transition: opacity var(--duration-spring-fast) var(--ease-m3-effects-fast),
                                  color var(--duration-spring-fast) var(--ease-m3-effects-fast); }

/* OriginOS 6 弹性动效（damping=0.6, stiffness=380） */
.spring-origin      { transition: all var(--duration-spring-default) var(--ease-origin-spring); }

/* ColorOS 16 干脆利落（damping=0.6, stiffness=800 ≈ 300ms） */
.spring-coloros     { transition: all var(--duration-spring-quick) var(--ease-coloros-quick); }
.spring-coloros-soft { transition: all var(--duration-spring-base) var(--ease-coloros-default); }

/* MagicOS 10 灵动胶囊（damping=0.65, stiffness=450） */
.spring-magicos     { transition: all var(--duration-spring-default) var(--ease-magicos-capsule); }
.spring-magicos-seamless { transition: all var(--duration-spring-base) var(--ease-magicos-seamless); }

/* One UI 9 流畅轻快（damping=0.7, stiffness=500） */
.spring-oneui       { transition: all var(--duration-spring-default) var(--ease-oneui-smooth); }

/* iOS 26 Liquid Glass spring */
.spring-ios         { transition: all var(--duration-spring-default) var(--ease-ios-spring); }
.spring-ios-morph   { transition: all var(--duration-spring-base) var(--ease-ios-glass-morph); }

/* Pixel UI / Material 3 Standard */
.spring-pixel       { transition: all var(--duration-spring-default) var(--ease-pixel-spring); }

/* 打断动画：transform-only + 短 duration（ColorOS 16 特色） */
.interruptible { transition: var(--transition-interruptible); }

/* 按压交互（Press 反馈）—— 替换原 press-scale 更细致 */
.press-spring-fast {
  transition: transform var(--duration-spring-quick) var(--ease-coloros-quick);
}
.press-spring-fast:active {
  transform: scale(0.94);
}

.press-spring-base {
  transition: transform var(--duration-spring-default) var(--ease-m3-spatial-fast);
}
.press-spring-base:active {
  transform: scale(0.96);
}

.press-spring-soft {
  transition: transform var(--duration-spring-fast) var(--ease-ios-spring);
}
.press-spring-soft:active {
  transform: scale(0.98);
}

/* Shape Morph（M3 Expressive 35 种形状）—— 圆 ↔ 方 形变 */
.shape-morph-pill-to-square {
  transition: border-radius var(--duration-spring-default) var(--ease-m3-spatial-fast);
}
.shape-morph-pill-to-square:active {
  border-radius: var(--shape-square-sm);
}

.shape-morph-circle-to-square {
  transition: border-radius var(--duration-spring-default) var(--ease-m3-spatial-fast);
}
.shape-morph-circle-to-square:active {
  border-radius: var(--shape-square-md);
}

/* ==============================================================
 * 10.6 Spring Morph + Liquid Glass 工具类
 * ============================================================== */

/* 液态玻璃弹性：按下时玻璃质感增强（弥散光） */
.glass-spring {
  transition: transform var(--duration-spring-default) var(--ease-ios-spring),
              box-shadow var(--duration-spring-base) var(--ease-out),
              background var(--duration-spring-fast) var(--ease-out);
}
.glass-spring:active {
  transform: scale(0.97);
  box-shadow: var(--light-diffuse-strong);
}

/* 灵动胶囊形变（MagicOS 10） */
.capsule-morph {
  transition: width var(--duration-spring-base) var(--ease-magicos-capsule),
              height var(--duration-spring-base) var(--ease-magicos-capsule),
              border-radius var(--duration-spring-base) var(--ease-magicos-capsule);
}

/* OriginOS 6 陀螺仪光影：轻微 3D 倾斜反馈（CSS 模拟） */
.gyro-tilt {
  transition: transform var(--duration-spring-base) var(--ease-magicos-capsule);
  transform-style: preserve-3d;
}

/* 弹性出现 / 消失（OriginOS 6 风格） */
.bounce-in {
  animation: bounce-in var(--duration-spring-base) var(--ease-origin-spring) both;
}
@keyframes bounce-in {
  0%   { opacity: 0; transform: scale(0.5) translateY(20rpx); }
  60%  { opacity: 1; transform: scale(1.05) translateY(-4rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

/* MagicOS 灵动胶囊形变动画（圆→胶囊→卡片） */
@keyframes capsule-morph-in {
  0%   { width: var(--capsule-height); border-radius: var(--capsule-radius); }
  60%  { width: calc(var(--capsule-height) * 1.5); }
  100% { width: 200rpx; border-radius: var(--capsule-radius); }
}
@keyframes capsule-expand {
  from { width: 200rpx; height: var(--capsule-height); border-radius: var(--capsule-radius); }
  to   { width: var(--capsule-expanded-width); height: var(--capsule-expanded-min-height); border-radius: var(--capsule-expanded-radius); }
}

/* Now Bar 通知出现（One UI 9） */
@keyframes nowbar-in {
  0%   { transform: translateY(40rpx) scale(0.8); opacity: 0; }
  60%  { transform: translateY(-4rpx) scale(1.05); opacity: 1; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}
.anim-nowbar-in {
  animation: nowbar-in var(--duration-spring-default) var(--ease-oneui-smooth) both;
}

/* AI 光晕脉冲（OriginOS 6 AI 动效） */
@keyframes ai-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.4); }
  50%  { box-shadow: 0 0 0 16rpx rgba(99, 102, 241, 0.12); }
  100% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0); }
}
.anim-ai-pulse {
  animation: ai-pulse 2s var(--ease-in-out) infinite;
}

/* AI 思考光晕（持续呼吸） */
@keyframes ai-thinking {
  0%, 100% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.5),
                       0 0 24rpx 4rpx rgba(99, 102, 241, 0.2); }
  50%      { box-shadow: 0 0 0 8rpx rgba(99, 102, 241, 0.2),
                       0 0 48rpx 8rpx rgba(99, 102, 241, 0.3); }
}
.anim-ai-thinking {
  animation: ai-thinking 1.6s var(--ease-in-out) infinite;
}

/* 充电岛能量脉冲（ColorOS 16.1） */
@keyframes charge-pulse {
  0%   { box-shadow: var(--charge-pulse-start); }
  100% { box-shadow: var(--charge-pulse-end); }
}
.anim-charge-pulse {
  animation: charge-pulse 1.6s var(--ease-out) infinite;
}

/* 渐进模糊（OriginOS 6 特色） */
@keyframes progressive-blur {
  from { filter: blur(0rpx); }
  to   { filter: blur(24rpx); }
}
.anim-progressive-blur {
  animation: progressive-blur var(--duration-spring-base) var(--ease-magicos-seamless) both;
}

/* 数字滚动（用于价格、统计数字） */
@keyframes number-pop {
  0%   { transform: translateY(8rpx) scale(0.92); opacity: 0; }
  50%  { transform: translateY(-2rpx) scale(1.04); }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}
.anim-number-pop {
  animation: number-pop var(--duration-spring-base) var(--ease-m3-spatial-fast) both;
}

/* 进度条填充（弹簧式增长） */
@keyframes progress-fill {
  from { transform: scaleX(0); }
  to   { transform: scaleX(1); }
}
.anim-progress-fill {
  transform-origin: left center;
  animation: progress-fill var(--duration-spring-slow) var(--ease-magicos-seamless) both;
}

/* 数据流入（柱状图） */
@keyframes bar-rise {
  from { transform: scaleY(0); }
  to   { transform: scaleY(1); }
}
.anim-bar-rise {
  transform-origin: bottom center;
  animation: bar-rise var(--duration-spring-base) var(--ease-m3-spatial-default) both;
}

/* 列表项错落入场（增强版） */
.anim-stagger-in {
  animation: bounce-in var(--duration-spring-base) var(--ease-origin-spring) both;
  animation-delay: var(--stagger-delay, 0ms);
}

/* ====================================================================
 * 12. 安全区与底栏留白（防止 tab-bar 遮挡）
 * ==================================================================== */
.safe-area-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 180rpx);
}
.safe-area-top {
  padding-top: env(safe-area-inset-top);
}
