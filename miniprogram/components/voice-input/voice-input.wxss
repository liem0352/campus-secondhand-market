/* ============================================================
 * 语音输入组件样式 — 融合 fusion-ui-design v2
 *
 * 动效来源：
 *   - MagicOS 10 灵动胶囊频谱岛（Part 22.13）
 *   - OriginOS 6 AI 光晕脉冲（Part 22.9）— 紫色 rgba(99,102,241,*)
 *   - ColorOS 16 充电岛能量（Part 22.10）
 *   - MD3 Expressive 弹性曲线（spring-m3-spatial-default）
 *
 * 设计 Token 全部走 var(--*)，减弱动效偏好自动降级。
 * ============================================================ */

.voice-input {
  padding: 24rpx 0;
  text-align: center;
  /* 灵动胶囊出现：圆 → 胶囊（MagicOS 10，class anim-capsule-in 在 app.wxss） */
}

.voice-input.disabled {
  opacity: var(--opacity-disabled, 0.5);
  pointer-events: none;
}

.voice-hint {
  font-size: var(--font-size-body, 26rpx);
  color: var(--color-text-secondary, #666);
  margin-bottom: 24rpx;
  min-height: 40rpx;
}

.voice-hint .partial {
  display: block;
  color: var(--color-success, #07c160);
  margin-top: 8rpx;
  font-size: var(--font-size-caption, 24rpx);
}

.voice-hint.recording-hint {
  color: var(--color-danger, #e54d42);
}

.voice-hint.processing {
  color: var(--ai-thinking, rgba(99, 102, 241, 0.85));
  /* AI 思考光晕（class anim-ai-pulse 在 app.wxss） */
}

.voice-hint.error {
  color: var(--color-danger, #e54d42);
}

.voice-hint.warn {
  color: var(--color-warning-strong, #ad6800);
  background: var(--color-warning-bg, #fff7e6);
  padding: 16rpx;
  border-radius: 8rpx;
  text-align: left;
  line-height: 1.5;
}

.pulse-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  background: var(--color-danger, #e54d42);
  border-radius: 50%;
  margin-right: 8rpx;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
}

/* ============================================================
 * MagicOS 10 灵动胶囊频谱岛（Part 22.13）
 *
 * 5 根 waveform bar，胶囊化容器，弹性波动
 * - 容器：999rpx 圆角胶囊
 * - 阴影：紫色 AI 光晕（与 OriginOS 6 联动）
 * - 5 根 bar 高度由 inline style (0-100%) 驱动
 * - 弹性波动由 app.wxss 的 .anim-spectrum-1~5 提供
 * ============================================================ */
.spectrum-island {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 320rpx;
  height: 80rpx;
  margin: 24rpx auto;
  padding: 0 24rpx;
  background: var(--color-bg-elevated, rgba(255, 255, 255, 0.92));
  border-radius: 999rpx; /* 胶囊圆角 — MagicOS 10 灵动胶囊 */
  box-shadow: var(--shadow-island,
    0 4rpx 24rpx rgba(99, 102, 241, 0.18));
  /* 灵动胶囊曲线（MagicOS 10 damping=0.65 stiffness=450） */
  transition:
    width var(--duration-spring-base) var(--ease-magicos-capsule),
    height var(--duration-spring-base) var(--ease-magicos-capsule),
    box-shadow var(--duration-spring-base) var(--ease-magicos-capsule),
    background var(--duration-spring-base) var(--ease-magicos-capsule);
  /* 入场：圆 → 胶囊的形态变换（anim-capsule-in 在 app.wxss） */
  animation: smart-capsule-in var(--duration-spring-base) var(--ease-magicos-capsule) both;
}

.spectrum-bar {
  width: 10rpx;
  min-height: 8rpx;
  max-height: 100%;
  /* 紫色 AI 渐变（OriginOS 6 AI 光晕色） */
  background: linear-gradient(180deg,
    rgba(99, 102, 241, 0.95) 0%,
    rgba(139, 92, 246, 0.95) 100%);
  border-radius: 6rpx;
  transform-origin: center;
  /* 弹性波动（class .anim-spectrum-1~5 已在 app.wxss，延迟 0/0.15/0.3/0.45/0.6s） */
  /* height 由 inline style 动态驱动（0-100% 范围） */
}

/* ============================================================
 * 麦克风按钮
 * 静态：anim-ai-thinking（OriginOS 6 持续呼吸光晕，紫色 99,102,241）
 * 录音中：anim-charge-wave（ColorOS 16 充电岛能量波动）
 * 过渡：spring-magicos-capsule（MagicOS 10 灵动胶囊曲线）
 * ============================================================ */
.mic-btn {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: var(--color-bg-button, #f5f5f5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-button,
    0 4rpx 16rpx rgba(0, 0, 0, 0.08));
  /* 灵动胶囊曲线（MagicOS 10） */
  transition:
    border-radius var(--duration-spring-base) var(--ease-magicos-capsule),
    background var(--duration-spring-base) var(--ease-magicos-capsule),
    box-shadow var(--duration-spring-base) var(--ease-magicos-capsule),
    transform var(--duration-spring-base) var(--ease-m3-spatial-default);
}

.mic-btn.recording {
  background: var(--color-danger-bg, #ffecec);
  /* ColorOS 16 充电岛能量波动（class anim-charge-wave 在 app.wxss） */
  /* 形态从圆 → 胶囊（MagicOS 10） */
  border-radius: 80rpx;
  box-shadow:
    0 0 0 8rpx rgba(229, 77, 66, 0.2),
    0 0 24rpx rgba(229, 77, 66, 0.3);
}

/* 静态待机：OriginOS 6 AI 思考呼吸光晕（紫色 rgba(99,102,241)） */
.mic-btn.anim-ai-thinking {
  background: rgba(99, 102, 241, 0.08);
}

/* CSS 绘制麦克风（用户规则 5：严禁 emoji） */
.mic-icon {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 麦克风头（圆角矩形） */
.mic-icon .mic-cap {
  position: absolute;
  top: 8rpx;
  width: 24rpx;
  height: 32rpx;
  border-radius: 12rpx;
  background: var(--color-text-secondary, #666);
  /* 弹簧式过渡：MD3 Expressive 默认 */
  transition: background var(--duration-spring-fast) var(--ease-m3-spatial-default);
}

/* 麦克风弧形支架 */
.mic-icon .mic-stand {
  position: absolute;
  bottom: 12rpx;
  width: 36rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: var(--color-text-secondary, #666);
  transition: background var(--duration-spring-fast) var(--ease-m3-spatial-default);
}

/* 麦克风底座 */
.mic-icon .mic-base {
  position: absolute;
  bottom: 4rpx;
  width: 16rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: var(--color-text-secondary, #666);
  transition: background var(--duration-spring-fast) var(--ease-m3-spatial-default);
}

/* 录音中：麦克风整体变红 */
.mic-btn.recording .mic-icon .mic-cap,
.mic-btn.recording .mic-icon .mic-stand,
.mic-btn.recording .mic-icon .mic-base {
  background: var(--color-danger, #e54d42);
}

.mic-label {
  font-size: var(--font-size-caption, 22rpx);
  color: var(--color-text-tertiary, #999);
  margin-top: 8rpx;
  /* MD3 Expressive 默认曲线 */
  transition: color var(--duration-spring-fast) var(--ease-m3-spatial-default);
}
.mic-btn.recording .mic-label {
  color: var(--color-danger, #e54d42);
}

/* ============================================================
 * 预览卡片
 * 入场：anim-m3-spatial-in（MD3 Expressive 弹性入场）
 * 过渡：spring-m3-spatial-default（MD3 默认 spring 曲线）
 * ============================================================ */
.preview-card {
  margin-top: 32rpx;
  padding: 24rpx;
  background: var(--color-bg-card, #fff);
  border-radius: 16rpx;
  text-align: left;
  box-shadow: var(--shadow-card,
    0 2rpx 12rpx rgba(0, 0, 0, 0.06));
  /* MD3 Expressive 默认弹性曲线 */
  transition:
    transform var(--duration-spring-base) var(--ease-m3-spatial-default),
    box-shadow var(--duration-spring-base) var(--ease-m3-spatial-default);
}

.preview-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: var(--font-size-body, 28rpx);
}

.preview-row .label {
  width: 80rpx;
  color: var(--color-text-tertiary, #999);
}

.preview-row .value {
  flex: 1;
  color: var(--color-text-primary, #333);
}

.preview-row .amount {
  font-weight: bold;
  color: var(--color-danger, #e54d42);
  font-size: var(--font-size-title, 36rpx);
}

.confidence {
  font-size: var(--font-size-caption, 22rpx);
  color: var(--color-success, #07c160);
  margin-left: 12rpx;
}

.confidence.warn {
  color: var(--color-warning, #ff976a);
}

.btn-link,
.btn-outline {
  font-size: var(--font-size-body, 26rpx);
  color: var(--color-success, #07c160);
  padding: 16rpx;
}

.btn-outline {
  border: 1rpx solid var(--color-success, #07c160);
  border-radius: 8rpx;
  text-align: center;
  margin-top: 16rpx;
}

.preview-actions {
  display: flex;
  justify-content: center;
}

/* ============================================================
 * 减弱动效偏好支持（a11y）
 *
 * 遵循 prefers-reduced-motion: 系统级 / 浏览器级减弱动效开关
 * 来源：WCAG 2.1 2.3.3 + 华为 EMUI / OriginOS 6 动效减弱开关
 *
 * 效果：
 * - 关闭频谱/呼吸/充电岛/胶囊 动画
 * - 频谱条回落为静态中位高度，避免视觉突变
 * - 关闭所有 transition / animation
 * ============================================================ */
@media (prefers-reduced-motion: reduce) {
  .spectrum-island,
  .spectrum-bar,
  .mic-btn,
  .mic-btn.recording,
  .preview-card,
  .pulse-dot,
  .voice-hint .partial {
    animation: none !important;
    transition: none !important;
  }
  .spectrum-bar {
    /* 减弱动效模式下使用静态中位高度，避免高度跳变 */
    height: 40% !important;
  }
}
