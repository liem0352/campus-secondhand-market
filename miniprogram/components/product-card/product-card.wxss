/* components/product-card/product-card.wxss
 * --------------------------------------------------------------------
 * 商品卡片样式 —— 融合 fusion-ui-design v2（Part 22）重构版
 *
 * 设计语言融合（每个新动效的设计来源已注释在对应 class 旁）：
 *   - iOS 26 Liquid Glass 折射层     —— 多层 inset 阴影 + 顶/底高光
 *   - iOS 26 anim-liquid-shine       —— 主图区折射光斑扫过（app.wxss）
 *   - MagicOS 10 anim-seamless       —— 一镜到底转场 keyframes
 *   - OriginOS 6 陀螺仪光影 .gyro-light —— 主图背景扫光 + JS 动态 transform
 *   - ColorOS 16 spring-coloros      —— 干脆利落（damping=0.6, stiffness=800）替换原 press-spring
 *   - MD3 Expressive 空间弹性         —— 入场 stagger + 过冲回弹
 *
 * 设计原则：
 *   1. 液态玻璃质感：半透 + 顶部高光 + 多层阴影 + 边缘内发光
 *   2. Spring 弹性动效：spring-coloros (0.94) + 心跳收藏
 *   3. 光感设计：主图陀螺仪扫光、价格光学字重对比
 *   4. 严格遵循 design tokens（颜色/字号/间距/动效/圆角/阴影）
 *
 * 严禁：
 *   - 硬编码 hex / rpx 数值（必须使用 var(--*)）
 *   - 使用 emoji 图标（用 SVG）
 */

/* ============== 基础卡片容器 ============== */
.pcard {
  position: relative;
  display: flex;
  flex-direction: column;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  /* 多层阴影模拟光感立体（参考 OriginOS 6 弥散光） */
  box-shadow:
    0 1rpx 2rpx rgba(15, 23, 42, 0.04),
    0 8rpx 24rpx rgba(15, 23, 42, 0.06),
    0 16rpx 48rpx rgba(15, 23, 42, 0.04);
  overflow: hidden;
  /* ColorOS 16 干脆利落（替换原 press-spring 的 ease-spring） */
  transition:
    transform var(--duration-spring-quick) var(--ease-coloros-quick),
    box-shadow var(--duration-base) var(--ease-out);
  /* 防止瀑布流内部换行 */
  break-inside: avoid;
  -webkit-column-break-inside: avoid;
  page-break-inside: avoid;
  /* 开启 GPU 加速，提升动画流畅度 */
  will-change: transform;
}

/* ----- 瀑布流：Liquid Glass 折射层（v2 新增） -----
   设计来源：iOS 26 Liquid Glass（融合体系 v2 关键 token）
   通过 --liquid-refract-prism（多层 inset）+ --liquid-edge-glow（边缘内发光）
   模拟玻璃厚度与折射；顶/底 1px 高光条模拟入射光与反射光 */
.pcard--waterfall {
  box-shadow:
    var(--liquid-refract-prism),
    var(--liquid-edge-glow),
    0 1rpx 2rpx rgba(15, 23, 42, 0.04),
    0 8rpx 24rpx rgba(15, 23, 42, 0.06),
    0 16rpx 48rpx rgba(15, 23, 42, 0.04);
  /* 顶/底高光描边：iOS 26 双侧折射 */
  border-top: 1rpx solid rgba(255, 255, 255, 0.55);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

/* 顶部高光条（液态玻璃关键细节 —— 入射光） */
.pcard__highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.6) 50%,
    transparent 100%
  );
  z-index: 4;
  pointer-events: none;
  /* 微高光强度 */
  opacity: 0.7;
}

/* 底部高光条（iOS 26 Liquid Glass 反射光 —— v2 新增） */
.pcard__highlight--bottom {
  top: auto;
  bottom: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.35) 50%,
    transparent 100%
  );
  opacity: 0.6;
}

.pcard__highlight--list {
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.5) 30%,
    rgba(255, 255, 255, 0.5) 70%,
    transparent 100%
  );
}

/* 按下态：spring-coloros 干脆利落（替换原 press-spring）
   设计来源：ColorOS 16（damping=0.6, stiffness=800）
   体感：快速按下、轻微回弹、无拖泥带水 */
.pcard--pressed,
.pcard:active {
  transform: scale(0.94);
  box-shadow:
    0 1rpx 2rpx rgba(15, 23, 42, 0.06),
    0 4rpx 12rpx rgba(15, 23, 42, 0.08);
  /* ColorOS 16 干脆利落过渡曲线 */
  transition:
    transform var(--duration-spring-quick) var(--ease-coloros-quick),
    box-shadow var(--duration-fast) var(--ease-out);
}

/* spring-coloros component 级 :active 兜底
   兼容：若 .press-scale 也命中 :active，由更高优先级决定最终值 */
.spring-coloros:active {
  transform: scale(0.94);
  transition: transform var(--duration-spring-quick) var(--ease-coloros-quick);
}

/* ============== 主图区（瀑布流） ============== */
.pcard__media {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--color-bg-section);
  overflow: hidden;
  /* 陀螺仪 transform 平滑过渡（ColorOS 16 干脆利落） */
  transition: transform var(--duration-spring-quick) var(--ease-coloros-quick);
  /* 注意：移除 transform-style: preserve-3d
     该属性在 overflow: hidden 下会破坏合成层，
     导致微信开发者工具 Chromium 渲染层将子元素 image 错误裁剪不可见。
     陀螺仪 3D 效果通过 perspective + rotateX/Y 已足够，无需 preserve-3d。 */
  will-change: transform;
}

.pcard__media--list {
  width: 220rpx;
  height: 220rpx;
  aspect-ratio: auto;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  align-self: flex-start;
}

.pcard__img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  /* 图片缩放过渡 */
  transition: transform var(--duration-slow) var(--ease-out);
}

.pcard:active .pcard__img {
  /* 按下时图片轻微缩放，强化空间感 */
  transform: scale(1.04);
}

/* 主图底部渐变遮罩：让 chip 文字更清晰（光感设计细节） */
.pcard__media-shade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 80rpx;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(0, 0, 0, 0.18) 100%
  );
  pointer-events: none;
  z-index: 1;
}

.pcard__media-shade--list {
  height: 50rpx;
}

/* ============== 收藏按钮（液态玻璃圆） ============== */
.pcard__fav {
  position: absolute;
  top: var(--space-2);
  right: var(--space-2);
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-circle);
  /* 液态玻璃：半透 + 高光（小程序不支持 backdrop-filter，用多层视觉技巧替代） */
  background: rgba(255, 255, 255, 0.65);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.8),
    0 4rpx 12rpx rgba(15, 23, 42, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  /* 触控热区扩展到 ≥ 88rpx */
  padding: 16rpx;
  margin: -16rpx;
  z-index: 2;
  /* spring-coloros 干脆利落（替换原 spring 曲线） */
  transition: transform var(--duration-spring-quick) var(--ease-coloros-quick);
}

.pcard__fav--active {
  background: rgba(255, 77, 79, 0.92);
  border-color: rgba(255, 77, 79, 0.5);
  box-shadow:
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.5),
    0 4rpx 12rpx rgba(255, 77, 79, 0.32);
}

.pcard__fav--inline {
  position: static;
  background: var(--color-bg-section);
  border: 1rpx solid var(--color-border-light);
  box-shadow: none;
  margin: 0;
  padding: 12rpx;
  width: 56rpx;
  height: 56rpx;
}

.pcard__fav--inline.pcard__fav--active {
  background: rgba(255, 77, 79, 0.12);
  border-color: rgba(255, 77, 79, 0.3);
  color: var(--color-primary);
}

.pcard__fav--pressed,
.pcard__fav:active {
  transform: scale(0.88);
}

.pcard__fav-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 收藏激活：心跳动画（spring-coloros 弹性 + 过冲回弹）
   设计来源：ColorOS 16 干脆利落 + iOS 26 弹性过冲
   体感：先放大到 1.4 → 收缩到 0.88 → 回弹到 1.08 → 平稳归位 */
@keyframes pcard-fav-pulse {
  0%   { transform: scale(1); }
  25%  { transform: scale(1.4); }
  50%  { transform: scale(0.88); }
  75%  { transform: scale(1.08); }
  100% { transform: scale(1); }
}

.pcard__fav--pulse {
  animation: pcard-fav-pulse 400ms var(--ease-coloros-quick);
}

/* ============== 成色 chip（液态玻璃 + 等级色） ============== */
.pcard__chip {
  position: absolute;
  left: var(--space-2);
  bottom: var(--space-2);
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-inverse);
  line-height: 1;
  /* 等级色 + 半透玻璃感（小程序不支持 backdrop-filter，纯色 + inset 高光替代） */
  background: rgba(0, 0, 0, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  z-index: 2;
}

.pcard__chip--list {
  left: var(--space-2);
  top: var(--space-2);
  bottom: auto;
}

.pcard__chip-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.9;
  /* 等级色圆点光晕 */
  box-shadow: 0 0 6rpx currentColor;
}

/* 等级色（覆盖 chip 默认背景） */
.cond-new       { background: linear-gradient(135deg, rgba(82, 196, 26, 0.95) 0%, rgba(56, 161, 14, 0.95) 100%); }
.cond-like-new  { background: linear-gradient(135deg, rgba(24, 144, 255, 0.95) 0%, rgba(9, 88, 217, 0.95) 100%); }
.cond-good      { background: linear-gradient(135deg, rgba(250, 140, 22, 0.95) 0%, rgba(217, 100, 4, 0.95) 100%); }
.cond-fair      { background: linear-gradient(135deg, rgba(245, 154, 35, 0.95) 0%, rgba(212, 119, 7, 0.95) 100%); }

/* ============== 文本区 ============== */
.pcard__body {
  padding: 16rpx 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  gap: 8rpx;
}

.pcard__body--list {
  padding: 12rpx 16rpx;
  flex: 1;
  min-width: 0;
  gap: 6rpx;
}

.pcard__title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 68rpx;
  /* 标题颜色更深一档，提升阅读层级 */
  letter-spacing: -0.01em;
}

/* ============== 价格行 ============== */
.pcard__row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-2);
}

.pcard__row--list {
  margin-top: 4rpx;
}

.pcard__row--footer {
  align-items: center;
  margin-top: 2rpx;
}

.pcard__row--actions {
  justify-content: flex-start;
  gap: var(--space-3);
  margin-top: 4rpx;
}

.pcard__price-wrap {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  min-width: 0;
}

.pcard__price-currency {
  font-size: 22rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  line-height: 1;
  margin-right: 2rpx;
}

.pcard__price {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  line-height: 1.1;
  font-family: -apple-system, "SF Pro Display", "PingFang SC", sans-serif;
  letter-spacing: -0.02em;
  /* 数字使用等宽数字 */
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum";
}

.pcard__price--list {
  font-size: 32rpx;
}

.pcard__price-original {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-decoration: line-through;
  margin-left: 6rpx;
  font-weight: var(--font-weight-regular);
}

/* ============== 学校徽标 ============== */
.pcard__school {
  display: flex;
  align-items: center;
  min-width: 0;
  max-width: 60%;
  gap: 6rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  padding: 2rpx 6rpx;
  border-radius: var(--radius-sm);
  transition: background-color var(--duration-fast) var(--ease-out);
}

.pcard__school--pressed,
.pcard__school:active {
  background: var(--color-bg-section);
}

.pcard__school-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  opacity: 0.6;
}

/* ============== 底部 meta ============== */
.pcard__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
  gap: var(--space-2);
}

.pcard__meta-right {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.pcard__meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-xs);
  font-variant-numeric: tabular-nums;
}

.pcard__meta-icon {
  width: 22rpx;
  height: 22rpx;
  opacity: 0.5;
}

/* ============== 列表模式 ============== */
.pcard--list {
  flex-direction: row;
  align-items: stretch;
  padding: 16rpx;
  gap: 16rpx;
  border-radius: var(--radius-lg);
}

.pcard--list .pcard__media--list {
  margin: 0;
}

/* 列表模式下隐藏瀑布流 meta（避免与底部 actions 重复） */
.pcard--list .pcard__meta { display: none; }

/* ============== 入场动画（瀑布流：MagicOS 10 一镜到底） ==============
   设计来源：MagicOS 10 一镜到底（页面切换无缝衔接）
   体感：下方弹起 → 轻微过冲 → 平稳归位；圆角由小变大再回稳
   使用 pcard 专属 keyframes（覆盖 app.wxss 中通用 seamless-morph） */
.pcard__anim {
  animation: pcard-fade-up var(--duration-spring-slow) var(--ease-magicos-seamless) both;
  animation-delay: var(--pcard-stagger, 0ms);
}

/* 列表模式入场（稍快的 MagicOS 一镜到底） */
.pcard__anim--list {
  animation: pcard-fade-up var(--duration-spring-base) var(--ease-magicos-seamless) both;
  animation-delay: var(--pcard-stagger, 0ms);
}

/* MagicOS 10 一镜到底 keyframes（v2 新增）
   关键节点：opacity 0→1 配合 translateY 40rpx→0，scale 0.94→1.02→1
   0% 卡片还未出现，40% 到达过冲点，100% 平稳归位 */
@keyframes pcard-fade-up {
  0%   { opacity: 0; transform: translateY(40rpx) scale(0.94); }
  40%  { opacity: 1; transform: translateY(-4rpx) scale(1.02); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

/* ============== 减弱动效偏好支持（v2 扩展） ==============
   设计来源：WCAG 2.3.3 + Apple Reduce Motion + Google Reduce Motion
   检测到 prefers-reduced-motion: reduce 时：
   - 关闭入场一镜到底（仅保留 opacity 渐入，无位移 / 缩放）
   - 关闭陀螺仪扫光（避免视觉眩晕）
   - 关闭心跳脉冲（避免重复刺激）
   - 按下反馈从 0.94 改为 0.98（轻微反馈仍保留）
   - 过渡曲线统一改为 ease-out（无弹性） */
@media (prefers-reduced-motion: reduce) {
  .pcard,
  .pcard__fav,
  .pcard__img,
  .pcard__media {
    transition: none;
  }
  .pcard--pressed,
  .pcard:active,
  .spring-coloros:active {
    transform: scale(0.98);
  }
  .pcard__fav--pulse {
    animation: none;
  }
  .pcard__anim,
  .pcard__anim--list {
    animation: pcard-fade-up-reduced var(--duration-base) linear both;
  }
  /* .gyro-light 在 app.wxss 中带 infinite 动画，此处关闭扫光 */
  .gyro-light {
    animation: none;
    background-image: none;
  }
  /* 陀螺仪动态 transform 也关闭（JS 端通过 utils/sys 走新设备信息 API 替代旧 API） */
  /* 注意：组件 wxss 不允许属性选择器，改为通过 JS 端 setData 清空 transform */
  .pcard__media {
    transform: none !important;
  }
}

/* 减弱动效下的简化入场（仅透明度，不做位移） */
@keyframes pcard-fade-up-reduced {
  from { opacity: 0; }
  to   { opacity: 1; }
}
